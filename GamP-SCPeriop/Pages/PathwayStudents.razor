@page "/pathway/{PathwayId:int}/students"
@using GamP_SCPeriop.Shared.Data
@layout TopNavBarLayout
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 px-3">

            <button class="btn btn-link text-decoration-none text-muted p-0 mb-4 fw-semibold" @onclick="GoToDashboard">
                <i class="bi bi-arrow-left me-2"></i> Voltar ao Dashboard
            </button>

            @if (isLoading)
            {
                <div class="d-flex justify-content-center mt-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (pathway == null)
            {
                <div class="alert alert-danger border-0 shadow-sm">Percurso não encontrado.</div>
            }
            else
            {
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-5 p-4 bg-white rounded-4 shadow-sm border-start border-primary border-4">
                    <div>
                        <span class="text-muted small text-uppercase fw-bold">Gestão do Percurso</span>
                        <h3 class="fw-bold text-dark mb-0">@pathway.Title</h3>
                    </div>
                    <div>
                        <button class="btn text-white px-4 py-2 rounded-pill fw-semibold shadow-sm"
                                style="background-color: #6A96A6;"
                                @onclick="GoToBuilder">
                            <i class="bi bi-pencil-square me-2"></i> Editar Estrutura
                        </button>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
                    <div class="card-body p-3">
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-0 text-muted fs-5"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control border-0 shadow-none ps-2"
                                   placeholder="Pesquisar aluno por nome..."
                                   @bind-value="searchQuery" @bind-value:event="oninput" />
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold mb-3 text-secondary">Supervisionados Inscritos</h5>

                @if (!FilteredEnrollments.Any())
                {
                    <div class="text-center p-5 bg-white rounded-4 border">
                        <i class="bi bi-people text-muted mb-2 fs-2"></i>
                        <p class="text-muted mb-0">Nenhum aluno encontrado.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var enrollment in FilteredEnrollments)
                        {
                            <div class="card border-0 shadow-sm rounded-4 bg-white" style="transition: transform 0.2s;">
                                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex justify-content-center align-items-center text-white"
                                             style="width: 45px; height: 45px; background-color: #E2ECEF; color: #6A96A6 !important;">
                                            <i class="bi bi-person-fill fs-4"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold text-dark mb-1">@enrollment.Student?.FullName</h6>
                                            <small class="text-muted">Progresso no Percurso: <strong>@enrollment.ProgressPercentage%</strong></small>
                                        </div>
                                    </div>
                                    <div>
                                        <button class="btn btn-outline-primary rounded-pill px-4 btn-sm fw-semibold"
                                                @onclick='() => Nav.NavigateTo($"/evaluate/{enrollment.Id}")'>
                                            Avaliar <i class="bi bi-chevron-right ms-1"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int PathwayId { get; set; }

    private Pathway? pathway;
    private List<Enrollment> enrollments = new();
    private bool isLoading = true;
    private string searchQuery = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;

            // 1. Vai buscar o percurso (para o título) usando o teu endpoint normal
            pathway = await Http.GetFromJsonAsync<Pathway>($"api/Pathway/{PathwayId}");

            // 2. Vai buscar as inscrições usando o novo endpoint que criámos acima
            var response = await Http.GetFromJsonAsync<List<Enrollment>>($"api/Pathway/{PathwayId}/enrollments");
            if (response != null)
            {
                enrollments = response;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading pathway details: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // Filtra a lista de inscrições diretamente em memória
    private IEnumerable<Enrollment> FilteredEnrollments =>
        enrollments?
            .Where(e => string.IsNullOrWhiteSpace(searchQuery) ||
                        (e.Student?.FullName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false))
        ?? Enumerable.Empty<Enrollment>();

    private void GoToDashboard() => Nav.NavigateTo("/dashboard");
    private void GoToBuilder() => Nav.NavigateTo($"/supervisor/pathway-builder/{PathwayId}?from=dashboard");
}