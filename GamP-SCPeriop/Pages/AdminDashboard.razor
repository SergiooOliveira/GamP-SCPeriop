@page "/admin/dashboard"
@layout TopNavBarLayout
@inject NavigationManager Nav

<div class="container mt-4">
    <div class="mb-5">
        <h2 class="fw-bold mb-0">Admin Dashboard</h2>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

        <!-- Cartão: Pathway Templates -->
        <div class="col">
            <div class="card border-0 h-100 admin-module-card" @onclick="NavigateToTemplates">
                <div class="card-body p-4 d-flex flex-column">

                    <!-- Ícone ilustrativo -->
                    <div class="mb-4 text-primary">
                        <i class="bi bi-collection-play" style="font-size: 2.5rem;"></i>
                    </div>

                    <h4 class="fw-bold text-dark mb-2" style="line-height: 1.2;">
                        Pathway Templates
                    </h4>

                    <p class="text-secondary small mt-auto mb-0">
                        Cria e gere os moldes dos percursos de aprendizagem e o seu sistema de Badges.
                    </p>

                </div>
            </div>
        </div>

        <!-- Espaço para futuros módulos (Ex: Gestão de Utilizadores, Configurações Globais) -->
        <!--
        <div class="col">
            <div class="card border-0 h-100 admin-module-card" @onclick="NavigateToUsers">
                ...
            </div>
        </div>
        -->

    </div>
</div>

@code {
    private void NavigateToTemplates()
    {
        // Navega para a página que construímos anteriormente
        Nav.NavigateTo("/templates");
    }
}