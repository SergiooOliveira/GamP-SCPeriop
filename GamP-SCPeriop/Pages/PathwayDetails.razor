@page "/pathway/{PathwayId:int}"
@using GamP_SCPeriop.Shared
@using Blazored.LocalStorage
@layout TopNavBarLayout
@inject HttpClient Http
@inject NavigationManager Nav
@inject ILocalStorageService LocalStorage

<div class="max-width-container mt-4">
    @if (pathway == null)
    {
        <p><em>A carregar detalhes...</em></p>
    }
    else
    {
        <h2 class="fw-bold">@pathway.Title</h2>
        
        <div class="mb-5">
            <h5 class="fw-bold mb-3">Estudantes Inscritos</h5>
            <div class="d-flex gap-3 overflow-auto pb-2">
                @if (enrollments == null)
                {
                    <p class="text-muted small">A carregar estudantes...</p>
                }
                else if (!enrollments.Any())
                {
                    <p class="text-muted small">Nenhum estudante inscrito neste percurso.</p>
                }
                else
                {
                    @foreach (var enrollment in enrollments)
                    {
                        <div class="card border-0 shadow-sm p-3 d-flex flex-row align-items-center gap-3" style="min-width: 250px; border-radius: 15px;">
                            <div class="rounded-circle bg-primary text-white d-flex justify-content-center align-items-center" style="width: 35px; height: 35px;">
                                <i class="bi bi-person"></i>
                            </div>
                            <div>
                                <div class="fw-bold small">@enrollment.Student?.DisplayShortName</div>
                                <div class="text-primary fw-bold" style="font-size: 0.8rem;">@enrollment.ProgressPercentage% concluído</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="row mt-4">
            @foreach (var module in pathway.Modules)
            {
                <div class="col-12 mb-3">
                    <div class="card border-0 shadow-sm p-3" style="border-radius: 15px;">
                        <h5 class="fw-bold text-primary">@module.Title</h5>
                        <hr />
                        <ul class="list-group list-group-flush">
                            @foreach (var comp in module.Components)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                                    <span>@comp.Title</span>
                                    <button class="btn btn-sm btn-outline-secondary" style="border-radius: 8px;">
                                        Ver Documento
                                    </button>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int PathwayId { get; set; }
    private Pathway? pathway;
    private List<Enrollment> enrollments = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. Get the Pathway structure
            pathway = await Http.GetFromJsonAsync<Pathway>($"api/Pathway/{PathwayId}");

            // 2. Get the specific students for this supervisor on THIS pathway
            var user = await LocalStorage.GetItemAsync<User>("user");
            var allEnrollments = await Http.GetFromJsonAsync<List<Enrollment>>($"api/Enrollment/supervisor/{user.Id}");
            
            if (allEnrollments != null)
            {
                enrollments = allEnrollments.Where(e => e.PathwayId == PathwayId).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro: {ex.Message}");
        }
    }
}