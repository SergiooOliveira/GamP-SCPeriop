@page "/module/{ModuleId:int}"
@using GamP_SCPeriop.Shared
@using static GamP_SCPeriop.Helpers.UIHelpers
@layout TopNavBarLayout
@inject HttpClient Http
@inject NavigationManager Nav

<div class="max-width-container mt-3 px-3">
    <div class="mb-3">
        <button class="btn btn-link text-muted p-0 text-decoration-none d-flex align-items-center" @onclick="GoBack">
            <i class="bi bi-chevron-left me-1"></i> Voltar
        </button>
    </div>

    @if (module == null)
    {
        <p>Carregando módulo...</p>
    }
    else
    {
        <div class="card detail-header-card shadow-sm mb-4">
            <div class="p-4 pb-3">
                <div class="d-flex align-items-center gap-3">
                    <h4 class="fw-bold mb-0">@module.Title</h4>
                    <div class="d-flex align-items-center flex-grow-1 gap-2">
                        <small class="text-muted">@module.Status</small>
                        <div class="bg-light flex-grow-1" style="height: 10px; border-radius: 10px;">
                            <div class="bg-primary h-100" style="width: @(module.ProgressPercentage)%; border-radius: 10px; opacity: 0.7;"></div>
                        </div>
                        <small class="text-muted">@(module.ProgressPercentage)%</small>
                    </div>
                </div>
            </div>

            <div class="detail-header-bottom">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-bold mb-0">@parentPathway?.Title</h6>
                        <small class="text-muted">João Silva</small>
                    </div>
                    <div class="text-end">
                        <small class="text-muted d-block mb-1">15, Abril 2025</small>
                        <div class="d-flex align-items-center gap-2">
                            <small class="text-primary small">@parentPathway?.Status</small>
                            <div class="bg-white" style="width: 50px; height: 6px; border-radius: 10px;">
                                <div class="bg-primary h-100" style="width: @(parentPathway?.TotalProgress ?? 0)%; border-radius: 10px; opacity: 0.7;"></div>
                            </div>
                            <small class="text-muted small">@(parentPathway?.TotalProgress ?? 0)%</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex flex-column gap-3">
            @foreach (var comp in module.Components)
            {
                <div class="card shadow-sm border-0 p-3" style="border-radius: 20px;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-chevron-right me-3 text-muted"></i>
                            <span class="fw-bold">@comp.Title</span>
                        </div>
                        <span class="badge rounded-pill @GetBadgeCss(comp.Status) px-3 py-2 border">@GetBadgeText(comp.Status)</span>
                    </div>
                </div>
            }
        </div>
    }

</div>

@code {
    [Parameter] public int ModuleId { get; set; }
    private Module? module;
    private Pathway? parentPathway;

    protected override async Task OnInitializedAsync()
    {
        var pathways = await Http.GetFromJsonAsync<List<Pathway>>("api/Pathway");
        module = pathways?.SelectMany(p => p.Modules).FirstOrDefault(m => m.Id == ModuleId);

        parentPathway = pathways?.FirstOrDefault(p => p.Modules.Any(m => m.Id == ModuleId));
    }

    private void GoBack() => Nav.NavigateTo("/my-profile");
}
