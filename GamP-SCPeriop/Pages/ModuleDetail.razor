@page "/module/{ModuleId:int}"
@using GamP_SCPeriop.Shared
@using GamP_SCPeriop.Shared.Entity.Model @using static GamP_SCPeriop.Helpers.UIHelpers
@layout TopNavBarLayout
@inject HttpClient Http
@inject NavigationManager Nav

<div class="max-width-container mt-3 px-3">
<div class="mb-3">
        <button class="btn btn-link text-muted p-0 text-decoration-none d-flex align-items-center" @onclick="GoBack">
            <i class="bi bi-chevron-left me-1"></i> Voltar
        </button>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (module == null)
    {
        <div class="alert alert-danger shadow-sm border-0" style="border-radius: 15px;">
            Módulo não encontrado ou sem permissão para visualizar.
        </div>
    }
    else
    {
        <div class="card detail-header-card shadow-sm mb-4">
            <div class="p-4 pb-3">
                <div class="d-flex align-items-center gap-3">
                    <h4 class="fw-bold mb-0">@module.Title</h4>
                    <div class="d-flex align-items-center flex-grow-1 gap-2">
                        <small class="text-muted">@module.Status</small>
                        <div class="bg-light flex-grow-1" style="height: 10px; border-radius: 10px;">
                            <div class="bg-primary h-100" style="width: @(module.ProgressPercentage)%; border-radius: 10px; opacity: 0.7;"></div>
                        </div>
                        <small class="text-muted">@(module.ProgressPercentage)%</small>
                    </div>
                </div>
            </div>

            <div class="detail-header-bottom border-top px-4 py-3 bg-light" style="border-radius: 0 0 10px 10px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-bold mb-0">@parentPathway?.Title</h6>
                        <small class="text-muted">Módulo do Percurso</small>
                    </div>
                    <div class="text-end">
                        <div class="d-flex align-items-center gap-2 mt-1">
                            <small class="text-primary small">Progresso Global</small>
                            <div class="bg-white border" style="width: 50px; height: 6px; border-radius: 10px;">
                                <div class="bg-primary h-100" style="width: @(parentPathway?.TotalProgress ?? 0)%; border-radius: 10px; opacity: 0.7;"></div>
                            </div>
                            <small class="text-muted small">@(parentPathway?.TotalProgress ?? 0)%</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex flex-column gap-3 mb-5">
            @if (module.Components != null && module.Components.Any())
            {
                @foreach (var comp in module.Components)
                {
                    <div class="card shadow-sm border-0 p-3" style="border-radius: 20px;">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-chevron-right me-3 text-muted"></i>
                                <span class="fw-bold">@comp.Title</span>
                            </div>
                            <span class="badge rounded-pill @GetBadgeCss(comp.Status) px-3 py-2 border">@GetBadgeText(comp.Status)</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center p-4 text-muted border rounded-4 bg-light">
                    Nenhuma componente encontrada neste módulo.
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int ModuleId { get; set; }
    
    private Module? module;
    private Pathway? parentPathway;
    private bool isLoading = true; // Added loading state

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            
            // 1. Fetch the module and its components
            module = await Http.GetFromJsonAsync<Module>($"api/Module/{ModuleId}");
            
            // 2. Use the PathwayId to fetch the parent pathway data
            if (module != null && module.PathwayId > 0)
            {
                parentPathway = await Http.GetFromJsonAsync<Pathway>($"api/Pathway/{module.PathwayId}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading module: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/my-profile");
}