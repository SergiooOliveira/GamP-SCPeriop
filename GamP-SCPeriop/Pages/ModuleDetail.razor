@page "/module/{ModuleId:int}"
@using GamP_SCPeriop.Shared.Data
@using GamP_SCPeriop.Shared.Enum
@using Blazored.LocalStorage
@using static GamP_SCPeriop.Helpers.UIHelpers
@layout TopNavBarLayout
@inject HttpClient Http
@inject NavigationManager Nav
@inject ILocalStorageService LocalStorage

<div class="max-width-container mt-3 px-3">
    <div class="mb-3">
        <button class="btn btn-link text-muted p-0 text-decoration-none d-flex align-items-center" @onclick="GoBack">
            <i class="bi bi-chevron-left me-1"></i> Voltar
        </button>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (module == null)
    {
        <div class="alert alert-danger shadow-sm border-0" style="border-radius: 15px;">
            Módulo não encontrado ou sem permissão para visualizar.
        </div>
    }
    else
    {
        <div class="card detail-header-card shadow-sm mb-4">
            <div class="p-4 pb-3">
                <div class="d-flex align-items-center gap-3">
                    <h4 class="fw-bold mb-0">@module.Title</h4>
                    <div class="d-flex align-items-center flex-grow-1 gap-2">
                        <small class="text-muted">@(moduleProgress == 100 ? "Concluído" : "Em Curso")</small>
                        <div class="bg-light flex-grow-1" style="height: 10px; border-radius: 10px;">
                            <div class="bg-primary h-100" style="width: @(moduleProgress)%; border-radius: 10px; opacity: 0.7; transition: width 0.5s ease-in-out;"></div>
                        </div>
                        <small class="text-muted">@(moduleProgress)%</small>
                    </div>
                </div>
            </div>

            <div class="detail-header-bottom border-top px-4 py-3 bg-light" style="border-radius: 0 0 10px 10px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-bold mb-0">@parentPathway?.Title</h6>
                        <small class="text-muted">Módulo do Percurso</small>
                    </div>
                    <div class="text-end">
                        <div class="d-flex align-items-center gap-2 mt-1">
                            <small class="text-primary small">Progresso Global</small>
                            <div class="bg-white border" style="width: 50px; height: 6px; border-radius: 10px;">
                                <div class="bg-primary h-100" style="width: @(globalProgress)%; border-radius: 10px; opacity: 0.7; transition: width 0.5s ease-in-out;"></div>
                            </div>
                            <small class="text-muted small">@(globalProgress)%</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5">
            @if (module.Components != null && module.Components.Any(c => c.Stage == ModuleStage.Teorica))
            {
                <h5 class="fw-bold mb-3 text-secondary"><i class="bi bi-journal-bookmark me-2"></i>Material de Estudo</h5>

                <div class="d-flex flex-column gap-2 mb-4">
                    @foreach (var comp in module.Components.Where(c => c.Stage == ModuleStage.Teorica))
                    {
                        var isOpen = expandedMaterials.Contains(comp.Id);

                        <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                            <div class="card-header bg-white border-0 p-3 d-flex justify-content-between align-items-center"
                                 style="cursor: pointer;" @onclick="() => ToggleMaterial(comp.Id)">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-file-earmark-text text-info me-3 fs-5"></i>
                                    <span class="fw-bold text-dark text-wrap">@comp.Title</span>
                                </div>
                                <div class="rounded-circle d-flex justify-content-center align-items-center bg-light flex-shrink-0" style="width: 32px; height: 32px;">
                                    <i class="bi @(isOpen ? "bi-chevron-up" : "bi-chevron-down") text-muted"></i>
                                </div>
                            </div>

                            @if (isOpen)
                            {
                                <div class="card-body bg-light border-top p-4">
                                    @if (!string.IsNullOrWhiteSpace(comp.Description))
                                    {
                                        <p class="text-secondary mb-3" style="white-space: pre-line; font-size: 0.9rem;">@comp.Description</p>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(comp.PdfFilePath))
                                    {
                                        <a href="@comp.PdfFilePath" target="_blank" class="btn btn-sm text-primary fw-semibold bg-primary bg-opacity-10 border-0 px-4 py-2" style="border-radius: 8px;">
                                            <i class="bi bi-file-earmark-pdf me-2 fs-6 align-middle"></i>Abrir Documento
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <div class="mb-5 mt-4">
            @if (module.Components != null && module.Components.Any(c => c.Stage == ModuleStage.PraticaSupervisionada))
            {
                <h5 class="fw-bold mb-3 text-secondary"><i class="bi bi-award me-2"></i>Avaliação Final (Prática Supervisionada)</h5>

                <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px; border-left: 5px solid #2c3e50;">
                    <div class="card-body p-4">
                        @{
                            // FILTRO: Apenas a fase de Avaliação Final (igual à lógica do PDF)
                            var assessableComponents = module.Components.Where(c => c.Stage == ModuleStage.PraticaSupervisionada).ToList();
                            var topLevelItems = assessableComponents.Where(c => c.ParentComponentId == null).ToList();
                        }

                        @if (topLevelItems.Any())
                        {
                            @foreach (var item in topLevelItems)
                            {
                                var children = assessableComponents.Where(c => c.ParentComponentId == item.Id).ToList();

                                @if (children.Any())
                                {
                                    <div class="mb-3 mt-4">
                                        <div class="d-flex align-items-center mb-2">
                                            <div style="width: 5px; height: 22px; background-color: #6A96A6; border-radius: 4px;" class="me-3 flex-shrink-0"></div>
                                            <h5 class="fw-bold mb-0 text-wrap" style="color: #1c4c5e;">@item.Title</h5>
                                        </div>
                                    </div>

                                    <div class="d-flex flex-column gap-2 mb-4">
                                        @foreach (var child in children)
                                        {
                                            <div class="card border-0 bg-light" style="border-radius: 10px;">
                                                <div class="card-body p-3 ms-4">
                                                    <div class="row align-items-center">
                                                        <div class="col-md-8 mb-2 mb-md-0 d-flex align-items-center">
                                                            <h6 class="fw-semibold mb-0 text-dark text-wrap" style="font-size: 0.95rem;">@child.Title</h6>
                                                        </div>
                                                        <div class="col-md-4 text-md-end">
                                                            <span class="badge rounded-pill @GetBadgeCss(child.Status) px-3 py-2 border shadow-sm" style="font-size: 0.75rem;">@GetBadgeText(child.Status)</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="card border-0 bg-light mb-3" style="border-radius: 10px;">
                                        <div class="card-body p-3">
                                            <div class="row align-items-center">
                                                <div class="col-md-8 mb-2 mb-md-0 d-flex align-items-center">
                                                    <div style="width: 5px; height: 22px; background-color: #adb5bd; border-radius: 4px;" class="me-3 flex-shrink-0"></div>
                                                    <h6 class="fw-bold mb-0 text-dark text-wrap">@item.Title</h6>
                                                </div>
                                                <div class="col-md-4 text-md-end">
                                                    <span class="badge rounded-pill @GetBadgeCss(item.Status) px-3 py-2 border shadow-sm" style="font-size: 0.75rem;">@GetBadgeText(item.Status)</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        }
                        else
                        {
                            <div class="alert alert-light text-center border mb-0 text-muted" style="border-radius: 8px;">
                                <i class="bi bi-info-circle me-2"></i> Ainda não existem parâmetros definidos para a Avaliação Final deste módulo.
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int ModuleId { get; set; }

    private Module? module;
    private Pathway? parentPathway;
    private bool isLoading = true;
    private HashSet<int> expandedMaterials = new HashSet<int>();

    // Novas variáveis para forçar o cálculo correto
    private int moduleProgress = 0;
    private int globalProgress = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            var currentUser = await LocalStorage.GetItemAsync<User>("user");
            if (currentUser != null)
            {
                module = await Http.GetFromJsonAsync<Module>($"api/Module/{ModuleId}/student/{currentUser.Id}");

                if (module != null && module.PathwayId > 0)
                {
                    // 1. Calcula o progresso REAL do Módulo (apenas Prática Supervisionada)
                    moduleProgress = CalculateModuleProgress(module);

                    // 2. Vai buscar a Inscrição específica deste aluno para calcular o Global!
                    var enrollments = await Http.GetFromJsonAsync<List<Enrollment>>($"api/Enrollment/student/{currentUser.Id}");
                    var enrollment = enrollments?.FirstOrDefault(e => e.PathwayId == module.PathwayId);

                    if (enrollment != null)
                    {
                        parentPathway = enrollment.Pathway;
                        globalProgress = CalculateGlobalProgress(enrollment);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading module: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleMaterial(int compId)
    {
        if (expandedMaterials.Contains(compId)) expandedMaterials.Remove(compId);
        else expandedMaterials.Add(compId);
    }

    private void GoBack() => Nav.NavigateTo("/my-profile");

    // --- MAGIA DOS CÁLCULOS SINCRONIZADOS ---
    private int CalculateModuleProgress(Module mod)
    {
        if (mod.Components == null) return 0;

        var assessable = mod.Components
                    .Where(c => c.Stage == ModuleStage.PraticaSupervisionada)
                    .Where(c => !mod.Components.Any(child => child.ParentComponentId == c.Id))
                    .ToList();

        if (!assessable.Any()) return 0;

        int completed = assessable.Count(c => c.Status == ComponentStatus.AcimaDaMedia || c.Status == ComponentStatus.Consistente);
        return (int)((double)completed / assessable.Count * 100);
    }

    private int CalculateGlobalProgress(Enrollment enrollment)
    {
        if (enrollment?.Pathway?.Modules == null) return 0;

        int totalComponents = 0;
        int completedComponents = 0;

        foreach (var mod in enrollment.Pathway.Modules)
        {
            if (mod.Components == null) continue;

            var assessable = mod.Components
                            .Where(c => c.Stage == ModuleStage.PraticaSupervisionada)
                            .Where(c => !mod.Components.Any(child => child.ParentComponentId == c.Id))
                            .ToList();

            totalComponents += assessable.Count;
            completedComponents += assessable.Count(c =>
                c.Status == ComponentStatus.AcimaDaMedia ||
                c.Status == ComponentStatus.Consistente);
        }

        return totalComponents > 0 ? (int)((double)completedComponents / totalComponents * 100) : 0;
    }
}