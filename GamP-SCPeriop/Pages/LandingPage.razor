@page "/login"
@using Gamp_SCPeriop.Shared
@layout EmptyLayout
@inject ILocalStorageService LocalStorage

@inject HttpClient Http
@inject NavigationManager Nav

<body>
    <EditForm Model="loginModel" onValidSubmit="HandleLogin">
        <DataAnnotationsValidator />

        <div class="container">
            <label for="uname"><b>Email</b></label>
            <InputText @bind-value="loginModel.Email" class="form-control" placeholder="Enter Email" required />
            <ValidationMessage For="@(() => loginModel.Email)" />

            <label for="psw"><b>Password</b></label>
            <InputText type="password" @bind-value="loginModel.Password" class="form-control" placeholder="Enter Password" required />
            <ValidationMessage For="@(() => loginModel.Password)" />

            <button type="submit">Login</button>
            <label>
                <input type="checkbox" checked="checked" name="remember"> Remember me
            </label>
        </div>

        <div class="container" style="background-color:#f1f1f1">
            <button type="button" class="cancelbtn">Cancel</button>
            <span class="psw">Forgot <a href="#">password?</a></span>
        </div>
    </EditForm>

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger mt-3">@error</div>
    }
</body>

@code {

    private UserLoginDTO loginModel = new UserLoginDTO();
    private string error = "";

    private async Task HandleLogin()
    {
        // Handle form submission logic here
        var response = await Http.PostAsJsonAsync("/api/auth/login", loginModel);
        var rawText = await response.Content.ReadAsStringAsync();

        if (response.IsSuccessStatusCode)
        {
            try
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var loggedInUser = System.Text.Json.JsonSerializer.Deserialize<User>(rawText, options);

                if (loggedInUser != null)
                {
                    await LocalStorage.SetItemAsync("user", loggedInUser);

                    if (loggedInUser.Role == UserRole.Supervisor)
                        Nav.NavigateTo("/dashboard");
                    else
                        Nav.NavigateTo("/my-profile");
                }
            }
            catch
            {
                error = $"JSON Error. The server actually sent this: {rawText}";
            }
        }
        else
        {
            error = $"Login Failed ({response.StatusCode}): {rawText}";
        }
    }
}