@page "/my-profile"
@using GamP_SCPeriop.Shared
@layout TopNavBarLayout
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject NavigationManager Nav
@inject HttpClient Http

<div class="container mt-4">
    <div class="row">
        <div class="max-width-container mt-3 px-2">
            <h4 class="fw-bold mb-4">My Pathways</h4>
            @if (pathways == null)
            {
                <p>Loading Pathways</p>
            }
            else
            {
                @foreach (var pathway in pathways)
                {
                    var isOpen = openPathways.Contains(pathway.Id);
                    <div class="card shadow-sm mb-3 border-0" style="border-radius: 25px;">
                        <div class="p-4 d-flex justify-content-between align-items-center no-select" @onclick="() => TogglePathway(pathway.Id)" style="cursor: pointer;">
                            <div class="d-flex align-items-center">
                                <i class="bi @(isOpen ? "bi-chevron-down" : "bi-chevron-right") me-3 text-muted"></i>
                                <div>
                                    <h5 class="fw-bold mb-0">@pathway.Title</h5>
                                    <small class="text-muted">Professor: João Silva</small>
                                </div>                                
                            </div>

                            <div class="text-end d-flex flex-column align-items-end">
                                <small class="text-muted mb-1" style="font-size: 0.7rem;">15, Abril 2025</small>
                                
                                <div class="d-flex align-items-center gap-2">
                                    <small class="text-muted">Em curso</small>

                                    <div class="bg-light" style="width: 60px; height: 6px; border-radius: 10px; overflow: hidden;">
                                        <div class="bg-primary h-100" style="width: 15%;"></div>
                                    </div>
                                        
                                    <small class="text-primary">15%</small>
                                </div>                                                                    
                            </div>
                        </div>
                        @if (isOpen)
                        {
                            <div class="px-4 pb-3">
                                @foreach (var module in pathway.Modules)
                                {
                                    var isModuleOpen = openModules.Contains(module.Id);

                                    <div class="d-flex justify-content-between align-items-center py-3 border-top no-select" @onclick="() => ToggleModule(module.Id)" style="cursor: pointer; border-radius: 15px;">
                                        <div>
                                            <span class="me-2">@(isModuleOpen ? "▼" : "▶")</span>
                                            <div class="fw-bold">@module.Title</div>
                                            <div class="text-success small">Concluído</div>
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <span class="badge rounded-pill bg-success-subtle text-success me-3">Aprovado</span>
                                            <i class="bi bi-eye text-primary"></i>
                                        </div>
                                    </div>

                                    @if (isModuleOpen)
                                    {
                                        <ul class="list-group list-group-flush ms-4">
                                            @foreach (var component in module.Components)
                                            {
                                                <li class="">
                                                    <span><i class="bi bi-file-earmark-pdf me-2"></i>@component.Title</span>
                                                    @if (!string.IsNullOrEmpty(component.PdfFilePath))
                                                    {
                                                        <button class="btn btn-sm btn-outline-secondary">Open Pdf</button>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    }
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private User? currentUser;
    private List<Pathway>? pathways;    

    private HashSet<int> openPathways = new HashSet<int>();
    private HashSet<int> openModules = new HashSet<int>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var hasUser = await LocalStorage.ContainKeyAsync("user");

            if (!hasUser)
            {
                Nav.NavigateTo("/login");
                return;
            }

            currentUser = await LocalStorage.GetItemAsync<User>("user");

            if (currentUser?.Role == UserRole.Supervisor)
            {
                Nav.NavigateTo("/dashboard");
                return;
            }

            pathways = await Http.GetFromJsonAsync<List<Pathway>>("api/Pathway");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Critical error: {ex.Message}");
        }
    }

    private async Task Logout()
    {
        await LocalStorage.RemoveItemAsync("user");
        Nav.NavigateTo("/login");
    }

    private void TogglePathway(int id)
    {
        if (openPathways.Contains(id))
        {
            openPathways.Remove(id);
        }
        else
        {
            openPathways.Add(id);
        }
    }

    private void ToggleModule(int id)
    {
        if (openModules.Contains(id))
        {
            openModules.Remove(id);
        }
        else
        {
            openModules.Add(id);
        }
    }
}
