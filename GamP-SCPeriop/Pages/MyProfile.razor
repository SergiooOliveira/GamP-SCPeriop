@page "/my-profile"
@using Blazored.LocalStorage
@using GamP_SCPeriop.Shared.Enum
@using GamP_SCPeriop.Shared.Data
@layout TopNavBarLayout
@inject HttpClient Http
@inject NavigationManager Nav
@inject ILocalStorageService LocalStorage

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 mt-3 px-2">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0" style="color: #2c3e50;">Os Meus Percursos</h4>
    
                @if (enrollments != null && enrollments.Any() && currentUser != null)
                {
                    <a href="api/Evaluation/student/@currentUser.Id/pdf" target="_blank" class="btn btn-sm text-white fw-bold shadow-sm" style="background-color: #6A96A6;">
                        <i class="bi bi-filetype-pdf me-2 fs-6 align-middle"></i>Exportar Relatório Global
                    </a>
                }
            </div>
            
            @if (enrollments == null)
            {
                <div class="d-flex justify-content-center mt-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (enrollments.Count == 0)
            {
                <div class="text-center mt-5 p-5 bg-light rounded-4 border-dashed">
                    <i class="bi bi-journal-x text-muted mb-3" style="font-size: 3rem;"></i>
                    <h5 class="fw-bold text-secondary">Nenhum Percurso Atribuído</h5>
                    <p class="text-muted small">Ainda não foste adicionado a nenhum percurso de avaliação.</p>
                </div>
            }
            else
            {
                @foreach (var enrollment in enrollments)
                {
                    var isOpen = openPathways.Contains(enrollment.PathwayId);
                    
                    <div class="card shadow-sm mb-4 border-0" style="border-radius: 20px; overflow: hidden; transition: all 0.2s;">
                        
                        <div class="p-4 d-flex justify-content-between align-items-center no-select bg-white hover-bg-light" 
                             @onclick="() => TogglePathway(enrollment.PathwayId)" 
                             style="cursor: pointer; border-left: 6px solid #6A96A6;">
                            
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px; background-color: #E2ECEF; color: #6A96A6;">
                                    <i class="bi @(isOpen ? "bi-chevron-down" : "bi-chevron-right") fs-5"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-1 text-dark">@enrollment.Pathway?.Title</h5>
                                    <small class="text-muted"><i class="bi bi-person-badge me-1"></i> Supervisor: @(enrollment.Professor?.DisplayShortName ?? "Atribuído")</small>
                                </div>                                
                            </div>

                            <div class="text-end d-flex flex-column align-items-end">
                                <small class="text-muted mb-2 fw-semibold" style="font-size: 0.75rem;">
                                    <i class="bi bi-calendar-event me-1"></i> Limite: @enrollment.EndDate.ToString("dd MMM yyyy")
                                </small>
                                
                                <div class="d-flex align-items-center gap-2">
                                    @{
                                        var globalProg = CalculateGlobalProgress(enrollment);
                                    }

                                    <small class="fw-bold" style="color: @(globalProg == 100 ? "#198754" : "#6A96A6");">
                                        @(globalProg == 100 ? "Concluído" : "Em Curso")
                                    </small>

                                    <div class="bg-light shadow-inner" style="width: 80px; height: 8px; border-radius: 10px; overflow: hidden;">
                                        <div class="h-100" style="width: @(globalProg)%; background-color: @(globalProg == 100 ? "#198754" : "#6A96A6"); transition: width 0.5s ease-in-out;"></div>
                                    </div>

                                    <small class="text-muted fw-bold">@(globalProg)%</small>
                                </div>
                                
                            </div>
                        </div>

                        @if (isOpen && enrollment.Pathway?.Modules != null)
                        {
                            <div class="bg-light p-3 border-top">                                

                                @foreach (var module in enrollment.Pathway.Modules)
                                {
                                    <div class="card border-0 shadow-sm mb-2" style="border-radius: 12px; transition: transform 0.1s; cursor: pointer;"
                                         @onclick='() => Nav.NavigateTo($"/module/{module.Id}")'>
                                        <div class="card-body p-3 d-flex justify-content-between align-items-center">

                                            <div class="d-flex align-items-center">
                                                <i class="bi bi-journal-text me-3 fs-4" style="color: #6A96A6;"></i>
                                                <div>
                                                    <div class="fw-bold text-dark mb-0">@module.Title</div>
                                                    <small class="text-muted" style="font-size: 0.75rem;">Clique para ver componentes</small>
                                                </div>
                                            </div>

                                            <div class="d-flex align-items-center gap-3">
                                                @{
                                                    var modProgress = CalculateModuleProgress(module);
                                                }

                                                @if (modProgress >= (enrollment.Pathway?.MinimumApprovalScore ?? 100))
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-1">
                                                        <i class="bi bi-check2-circle me-1"></i> Aprovado
                                                    </span>
                                                }
                                                else if (module.Status == "Em curso" || modProgress > 0)
                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-3 py-1">
                                                        Em Curso (@(modProgress)%)
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3 py-1">
                                                        Pendente
                                                    </span>
                                                }

                                                <div class="rounded-circle d-flex justify-content-center align-items-center" style="width: 35px; height: 35px; background-color: #f8f9fa;">
                                                    <i class="bi bi-arrow-right text-primary"></i>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private User? currentUser;
    private List<Enrollment>? enrollments;

    // We only need to track open pathways now
    private HashSet<int> openPathways = new HashSet<int>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var hasUser = await LocalStorage.ContainKeyAsync("user");

            if (!hasUser)
            {
                Nav.NavigateTo("/login");
                return;
            }

            currentUser = await LocalStorage.GetItemAsync<User>("user");

            // Redirect supervisors away from the student profile
            if (currentUser?.Role == UserRole.Supervisor)
            {
                Nav.NavigateTo("/dashboard");
                return;
            }

            // Fetch the enrollments for the student
            enrollments = await Http.GetFromJsonAsync<List<Enrollment>>($"api/Enrollment/student/{currentUser!.Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Critical error: {ex.Message}");
        }
    }

    private void TogglePathway(int id)
    {
        if (openPathways.Contains(id))
        {
            openPathways.Remove(id);
        }
        else
        {
            openPathways.Add(id);
        }
    }

    private int CalculateGlobalProgress(Enrollment enrollment)
    {
        if (enrollment?.Pathway?.Modules == null) return 0;

        int totalComponents = 0;
        int completedComponents = 0;

        foreach (var module in enrollment.Pathway.Modules)
        {
            if (module.Components == null) continue;

            var assessable = module.Components
                .Where(c => c.Stage == ModuleStage.PraticaSupervisionada)
                .Where(c => !module.Components.Any(child => child.ParentComponentId == c.Id))
                .ToList();

            totalComponents += assessable.Count;
            completedComponents += assessable.Count(c =>
                c.Status == ComponentStatus.AcimaDaMedia ||
                c.Status == ComponentStatus.Consistente);
        }

        return totalComponents > 0 ? (int)((double)completedComponents / totalComponents * 100) : 0;
    }

    private int CalculateModuleProgress(Module mod)
    {
        if (mod.Components == null) return 0;

        var assessable = mod.Components
                    .Where(c => c.Stage == ModuleStage.PraticaSupervisionada)
                    .Where(c => !mod.Components.Any(child => child.ParentComponentId == c.Id))
                    .ToList();

        if (!assessable.Any()) return 0;

        int completed = assessable.Count(c => c.Status == ComponentStatus.AcimaDaMedia || c.Status == ComponentStatus.Consistente);
        return (int)((double)completed / assessable.Count * 100);
    }
}