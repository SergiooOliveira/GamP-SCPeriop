@code {
    private User? currentUser;
    private List<Enrollment> supervisedEnrollments = new();
    
    // Helper record to group data for the top cards
    private record PathwaySummary(Pathway Pathway, int StudentCount);
    private List<PathwaySummary> pathwaySummaries = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. Verify session
            var hasUser = await LocalStorage.ContainKeyAsync("user");
            if (!hasUser)
            {
                Nav.NavigateTo("/login");
                return;
            }

            currentUser = await LocalStorage.GetItemAsync<User>("user");

            if (currentUser?.Role != UserRole.Supervisor)
            {
                Nav.NavigateTo("/"); // Kick out non-supervisors
                return;
            }

            // 2. Fetch data from the new API endpoint
            var fetchedData = await Http.GetFromJsonAsync<List<Enrollment>>($"api/Enrollment/supervisor/{currentUser.Id}");
            
            if (fetchedData != null)
            {
                supervisedEnrollments = fetchedData;

                // 3. Group the data for the carousel cards
                pathwaySummaries = supervisedEnrollments
                    .Where(e => e.Pathway != null)
                    .GroupBy(e => e.Pathway!)
                    .Select(g => new PathwaySummary(g.Key, g.Count()))
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Critical error loading dashboard: {ex.Message}");
        }
    }
}
