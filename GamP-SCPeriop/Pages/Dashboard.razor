@page "/dashboard"
@using GamP_SCPeriop.Shared.Entity.Model
@using GamP_SCPeriop.Shared.Enum
@using GamP_SCPeriop.Shared.Data
@using GamP_SCPeriop.Shared.Data.Template
@using Blazored.LocalStorage
@layout TopNavBarLayout
@inject HttpClient Http
@inject NavigationManager Nav
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JsRuntime

<div class="max-width-container mt-3 px-3 pb-5">
    
    <div class="d-flex overflow-auto gap-3 mb-4 pb-2 horizontal-scroll-container">
        @if (pathwaySummaries.Any())
        {
            @foreach (var summary in pathwaySummaries)
            {
                <div class="card border-0 shadow-sm flex-shrink-0 position-relative" style="width: 240px; border-radius: 20px; background-color: #E2ECEF;">

                    <!-- Botão de Apagar -->
                    <button class="btn btn-link text-danger position-absolute top-0 end-0 p-2"
                            style="z-index: 10;"
                            @onclick="() => DeletePathway(summary.Id)"
                            @onclick:stopPropagation="true">
                        <i class="bi bi-trash3 fs-5"></i>
                    </button>

                    <div @onclick='() => Nav.NavigateTo($"/pathway/{summary.Id}/students")' class="card-body p-4" style="cursor: pointer;">
                        <h6 class="fw-bold mb-3 fs-5">@summary.Title</h6>
                        <div class="mb-4 d-flex align-items-baseline">
                            <span class="fs-2 fw-bold me-2">@summary.StudentCount</span>
                            <span class="text-muted small">Supervisionados</span>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted flex-shrink-0 me-3">A carregar pathways...</p>
        }

        <div class="card shadow-sm flex-shrink-0"
             style="width: 240px; border-radius: 20px; background-color: transparent; border: 2px dashed #6A96A6; cursor: pointer; transition: all 0.2s;"
             @onclick="OpenCreatePathwayModal">
            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center h-100" style="color: #6A96A6; min-height: 160px;">
                <i class="bi bi-plus-circle mb-2" style="font-size: 2.5rem;"></i>
                <h6 class="fw-bold mb-0 fs-5">Criar Novo<br>Pathway</h6>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <div class="row mt-5 mb-4 align-items-center">
            <div class="col-md-6">
                <h4 class="fw-bold mb-0 text-dark">Gestão de Alunos</h4>
            </div>
            <div class="col-md-6 text-md-end mt-3 mt-md-0">
                <div class="input-group shadow-sm" style="border-radius: 20px; overflow: hidden; max-width: 350px; float: right;">
                    <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control border-0 bg-white" placeholder="Pesquisar aluno..." @bind="searchQuery" @bind:event="oninput">
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-5" style="border-radius: 20px; overflow: hidden;">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4 fw-bold border-0 py-3">Aluno</th>
                            <th class="fw-bold border-0 py-3">Email</th>
                            <th class="fw-bold border-0 py-3">Percursos Ativos</th>
                            <th class="fw-bold border-0 py-3">Progresso Global</th>
                            <th class="fw-bold border-0 py-3 text-end pe-4">Último Acesso</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (students == null)
                        {
                            <tr><td colspan="5" class="text-center py-4 text-muted">A carregar alunos...</td></tr>
                        }
                        else if (!students.Any())
                        {
                            <tr><td colspan="5" class="text-center py-4 text-muted">Nenhum aluno encontrado no sistema.</td></tr>
                        }
                        else
                        {
                            @foreach (var student in FilteredStudents)
                            {
                                <tr @onclick="() => OpenStudentProfile(student.StudentId)" style="cursor: pointer;" class="bg-white">
                                    <td class="no-select ps-4 py-3">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle text-white d-flex justify-content-center align-items-center flex-shrink-0 shadow-sm" style="width: 40px; height: 40px; background-color: #1a73e8;">
                                                <i class="bi bi-person-fill fs-5"></i>
                                            </div>
                                            <div class="fw-bold text-dark">@student.FullName</div>
                                        </div>
                                    </td>
                                    <td class="no-select text-muted small">@student.Email</td>
                                    <td>
                                        @if (!student.ActivePathways.Any())
                                        {
                                            <span class="text-muted small">Sem percursos</span>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-wrap gap-1">
                                                @foreach (var tag in student.ActivePathways)
                                                {
                                                    <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary fw-normal px-2 py-1 border border-primary border-opacity-25">@tag.Title</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td class="no-select" style="width: 200px;">
                                        <div class="d-flex align-items-center gap-2 bg-light px-3 py-2" style="border-radius: 20px;">
                                            <div class="bg-white flex-grow-1 shadow-sm" style="height: 6px; border-radius: 10px; overflow: hidden;">
                                                <div class="h-100" style="width: @(student.OverallProgress)%; background-color: #8ab4f8;"></div>
                                            </div>
                                            <small class="fw-bold text-primary" style="min-width: 30px; text-align: right;">@(student.OverallProgress)%</small>
                                        </div>
                                    </td>
                                    <td class="no-select text-end pe-4 text-muted small">
                                        @(student.LastAccess?.ToString("dd MMM yyyy") ?? "-")
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal-backdrop fade show" style="background-color: rgba(0,0,0,0.5);"></div>
    <div class="modal fade show d-block" tabindex="-1" @onclick="CloseModal">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content border-0 shadow" style="border-radius: 20px;">
                
                <div class="modal-header border-0 pb-0 d-flex flex-column align-items-center mt-4">
                    <button type="button" class="btn-close position-absolute top-0 end-0 m-3" @onclick="CloseModal"></button>
                    
                    <div class="rounded-circle text-white d-flex justify-content-center align-items-center mb-3 shadow-sm" style="width: 80px; height: 80px; background-color: #1a73e8;">
                        <i class="bi bi-person-fill" style="font-size: 2.5rem;"></i>
                    </div>

                    <h4 class="fw-bold mb-0 text-dark">@(selectedStudent?.FullName ?? "A carregar...")</h4>
                    <p class="text-muted small mb-2">@(selectedStudent?.Email)</p>
                </div>

                <div class="modal-body px-4 pb-4">
                    <hr class="text-muted opacity-25">
                    
                    <h6 class="fw-bold mb-3 text-dark">Atribuir Novo Percurso</h6>
                    <div class="d-flex gap-2">
                        <select class="form-select border-0 bg-light shadow-sm" style="border-radius: 10px;" @bind="selectedPathwayId">
                            <option value="0" selected disabled>Selecione um percurso...</option>
                            @foreach (var pathway in unassignedPathways)
                            {
                                <option value="@pathway.PathwayId">@pathway.Title</option>
                            }
                        </select>

                        <button class="btn btn-primary px-4 shadow-sm" style="border-radius: 10px; background-color: #1a73e8; border: none;"
                                @onclick="AssignPathway" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            }
                            else
                            {
                                <span>Adicionar</span>
                            }
                        </button>
                    </div>

                    <div class="mt-4">
                        <h6 class="fw-bold mb-2 text-dark">Percursos Atuais</h6>
                        <ul class="list-group list-group-flush small">
                            @if (selectedStudent?.ActivePathways == null || !selectedStudent.ActivePathways.Any())
                            {
                                <li class="list-group-item px-0 text-muted border-0 bg-transparent">
                                    <i class="bi bi-info-circle me-2"></i> Nenhum percurso atribuído.
                                </li>
                            }
                            else
                            {
                                @foreach (var pathway in selectedStudent.ActivePathways)
                                {
                                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center border-0 bg-transparent">
                                        <span><i class="bi bi-journal-text me-2 text-primary"></i> @pathway.Title</span>
                                        <span class="badge @(pathway.Status == "Concluído" ? "bg-success text-white" : "bg-light text-dark border")">
                                            @pathway.Status
                                        </span>
                                    </li>
                                }
                            }
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </div>
}


@if (showCreatePathwayModal)
{
    <div class="modal-backdrop fade show" style="background-color: rgba(0,0,0,0.5);"></div>
    <div class="modal fade show d-block" tabindex="-1" @onclick="CloseCreatePathwayModal">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content border-0 shadow" style="border-radius: 20px;">
                
                <div class="modal-header border-0 pb-0 d-flex flex-column align-items-center mt-4">
                    <button type="button" class="btn-close position-absolute top-0 end-0 m-3" @onclick="CloseCreatePathwayModal"></button>
                    
                    <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex justify-content-center align-items-center mb-3 shadow-sm" style="width: 80px; height: 80px;">
                        <i class="bi bi-diagram-3-fill" style="font-size: 2.5rem;"></i>
                    </div>

                    <h4 class="fw-bold mb-0 text-dark">Criar Novo Percurso</h4>
                    <p class="text-muted small mb-2 text-center">Defina os critérios básicos para começar.</p>
                </div>

                <div class="modal-body px-4 pb-4 mt-2">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary small mb-1">Título do Percurso</label>
                        <input class="form-control border-0 shadow-sm bg-light" style="border-radius: 10px; padding: 12px;" placeholder="Ex: Enfermagem Cirúrgica..." @bind="pathwayDto.Title" />
                    </div>

                    <div class="row mb-4">
                        <div class="col-6">
                            <label class="form-label fw-semibold text-secondary small mb-1">Mín. Passar (%)</label>
                            <input type="number" class="form-control border-0 shadow-sm bg-light" style="border-radius: 10px; padding: 12px;" @bind="pathwayDto.MinimumPassScore" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold text-secondary small mb-1">Mín. Aprovação (%)</label>
                            <input type="number" class="form-control border-0 shadow-sm bg-light" style="border-radius: 10px; padding: 12px;" @bind="pathwayDto.MinimumApprovalScore" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold mb-1">Molde Base (Opcional)</label>
                        <select class="form-select form-select-sm bg-light border-0" @bind="selectedTemplateId">
                            <option value="0">Nenhum (Criar percurso em branco)</option>
                            @if (availableTemplates != null)
                            {
                                @foreach (var template in availableTemplates)
                                {
                                    <option value="@template.Id">@template.Title</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="d-flex flex-column gap-2 mt-2">
                        <!-- O teu botão original -->
                        <button class="btn w-100 text-white fw-bold py-3 shadow-sm" style="border-radius: 10px; background-color: #6A96A6;"
                                @onclick="CreatePathway" disabled="@isCreatingPathway">
                            @if (isCreatingPathway)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>A criar...</span>
                            }
                            else
                            {
                                <span>Criar e Editar Percurso <i class="bi bi-arrow-right ms-2"></i></span>
                            }
                        </button>
                        
                        <!-- O novo botão para os Templates -->
                        <button class="btn w-100 fw-bold py-3 shadow-sm text-secondary" style="border-radius: 10px; background-color: #E2ECEF; border: none;"
                                @onclick='() => Nav.NavigateTo("/templates")'>
                            <i class="bi bi-collection me-2"></i> Explorar e Gerir Moldes Base
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // --- STATE VARIABLES ---
    private User? currentUser;

    // Top Cards Data
    private List<Enrollment> supervisedEnrollments = new();
    private record PathwaySummary(int Id, string Title, int StudentCount);
    private List<PathwaySummary> pathwaySummaries = new();

    // Table Data
    private List<StudentManagementDto>? students;
    private string searchQuery = "";

    // Modal Data
    private bool showModal = false;
    private int selectedStudentId;
    private StudentManagementDto? selectedStudent;
    private int selectedPathwayId;
    private bool isSubmitting = false;
    private List<PathwayTagDto> availablePathways = new();
    private List<PathwayTagDto> unassignedPathways = new();

    private int selectedTemplateId = 0;
    private List<PathwayTemplate> availableTemplates = new();

    // --- CREATE PATHWAY VARIABLES ---
    private bool showCreatePathwayModal = false;
    private bool isCreatingPathway = false;
    private PathwayCreateDTO pathwayDto = new PathwayCreateDTO { MinimumPassScore = 50, MinimumApprovalScore = 75 };

    // --- COMPUTED PROPERTIES ---
    private IEnumerable<StudentManagementDto> FilteredStudents =>
        string.IsNullOrWhiteSpace(searchQuery)
            ? (students ?? new())
            : (students ?? new()).Where(s => s.FullName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                                             s.Email.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    // --- INITIALIZATION ---
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var hasUser = await LocalStorage.ContainKeyAsync("user");
            if (!hasUser) { Nav.NavigateTo("/"); return; }

            currentUser = await LocalStorage.GetItemAsync<User>("user");
            if (currentUser?.Role != UserRole.Supervisor) { Nav.NavigateTo("/"); return; }

            availableTemplates = await Http.GetFromJsonAsync<List<PathwayTemplate>>("api/PathwayTemplate") ?? new();

            await LoadDashboardData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Critical error loading dashboard: {ex.Message}");
        }
    }

    private async Task LoadDashboardData()
    {
        // 1. Fetch ALL available pathways FIRST (This guarantees empty pathways are loaded!)
        availablePathways = await Http.GetFromJsonAsync<List<PathwayTagDto>>($"api/Pathway/supervisor/{currentUser!.Id}") ?? new();

        // 2. Fetch the Enrollments
        var fetchedData = await Http.GetFromJsonAsync<List<Enrollment>>($"api/Enrollment/supervisor/{currentUser!.Id}");
        if (fetchedData != null)
        {
            supervisedEnrollments = fetchedData;
        }

        // 3. THE FIX: Build cards for EVERY pathway, counting enrollments if they exist!
        pathwaySummaries = availablePathways.Select(p => new PathwaySummary(
            p.PathwayId,
            p.Title,
            supervisedEnrollments.Count(e => e.PathwayId == p.PathwayId)
        )).ToList();

        // 4. Fetch data for the Student Table
        students = await Http.GetFromJsonAsync<List<StudentManagementDto>>("api/Enrollment/management");
    }

    // --- MODAL LOGIC ---
    private void OpenStudentProfile(int studentId)
    {
        selectedStudentId = studentId;
        selectedStudent = students?.FirstOrDefault(s => s.StudentId == studentId);

        if (selectedStudent != null)
        {
            unassignedPathways = availablePathways
                .Where(p => !selectedStudent.ActivePathways.Any(ap => ap.PathwayId == p.PathwayId))
                .ToList();
        }
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        selectedPathwayId = 0;
    }

    private async Task AssignPathway()
    {
        if (selectedPathwayId == 0 || currentUser == null) return;

        isSubmitting = true;
        var payload = new EnrollmentDto
        {
            StudentId = selectedStudentId,
            ProfessorId = currentUser.Id,
            PathwayId = selectedPathwayId,
            ProgressPercentage = 0,
            EndDate = DateTime.Now.AddMonths(6)
        };

        var response = await Http.PostAsJsonAsync("api/Enrollment", payload);

        if (response.IsSuccessStatusCode)
        {
            // Close the modal and reload the data so BOTH the table and top cards update instantly!
            CloseModal();
            await LoadDashboardData();
        }
        else
        {
            Console.WriteLine("Failed to assign pathway.");
        }

        isSubmitting = false;
    }

    // --- CREATE PATHWAY LOGIC ---
    private void OpenCreatePathwayModal()
    {
        // Reset the form every time we open it
        pathwayDto = new PathwayCreateDTO { Title = "", MinimumPassScore = 50, MinimumApprovalScore = 75 };
        showCreatePathwayModal = true;
    }

    private void CloseCreatePathwayModal()
    {
        showCreatePathwayModal = false;
    }

    private async Task CreatePathway()
    {
        if (string.IsNullOrWhiteSpace(pathwayDto.Title)) return;

        isCreatingPathway = true;

        Console.WriteLine($"Creating a new pathway with a currentUser.id: {currentUser.Id}");
        pathwayDto.ProfessorId = currentUser.Id;

        // A TUA NOVA LINHA AQUI: Passa a escolha do Molde para o DTO
        pathwayDto.TemplateId = selectedTemplateId > 0 ? selectedTemplateId : null;

        var response = await Http.PostAsJsonAsync("api/Pathway", pathwayDto);
        if (response.IsSuccessStatusCode)
        {
            var createdPathway = await response.Content.ReadFromJsonAsync<Pathway>();
            if (createdPathway != null)
            {
                // Close the modal and instantly warp to the builder page using the brand new ID!
                showCreatePathwayModal = false;
                Nav.NavigateTo($"/supervisor/pathway-builder/{createdPathway.Id}?from=dashboard");
            }
        }
        else
        {
            Console.WriteLine("Erro ao criar percurso.");
        }
        
        isCreatingPathway = false;
    }

    private async Task DeletePathway(int pathwayId)
    {
        bool confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Tem a certeza que deseja apagar este percurso? Esta ação não pode ser revertida.");
        if (!confirmed) return;

        var response = await Http.DeleteAsync($"api/Pathway/{pathwayId}");
        if (response.IsSuccessStatusCode)
        {
            // Remove da lista em memória e atualiza o ecrã instantaneamente
            pathwaySummaries.RemoveAll(p => p.Id == pathwayId);
            StateHasChanged();
        }
    }
}