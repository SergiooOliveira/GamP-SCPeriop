@page "/evaluate/{EnrollmentId:int}"
@using GamP_SCPeriop.Shared.Data
@using GamP_SCPeriop.Shared.Enum
@layout TopNavBarLayout
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 px-3">

            <button class="btn btn-link text-decoration-none text-muted p-0 mb-4 fw-semibold" @onclick="GoBack">
                <i class="bi bi-arrow-left me-2"></i> Voltar ao Dashboard
            </button>

            @if (isLoading)
            {
                <div class="d-flex justify-content-center mt-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (enrollment == null)
            {
                <div class="alert alert-danger shadow-sm border-0" style="border-radius: 15px;">
                    Inscrição não encontrada.
                </div>
            }
            else
            {
                <div class="card shadow-sm border-0 mb-5" style="border-radius: 20px; background-color: #6A96A6; color: white;">
                    <div class="card-body p-4 p-md-5">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge bg-white text-dark bg-opacity-25 px-3 py-2" style="border-radius: 10px;">Ficha de Avaliação</span>
                            <span class="fw-bold text-white fs-5">@enrollment.ProgressPercentage% Concluído</span>
                        </div>
                        <h3 class="fw-bold mb-1">@enrollment.Student?.DisplayShortName</h3>
                        <p class="mb-0 text-white-50">Percurso: @enrollment.Pathway?.Title</p>
                    </div>
                </div>

                @if (enrollment.Pathway?.Modules != null)
                {
                    @foreach (var module in enrollment.Pathway.Modules)
                    {
                        <div class="card shadow-sm border-0 mb-5" style="border-radius: 15px; border-left: 5px solid #2c3e50;">
                            <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                                <h4 class="fw-bold text-uppercase mb-0" style="color: #2c3e50; letter-spacing: 1px;">@module.Title</h4>
                            </div>

                            <div class="card-body p-4">
                                @if (module.Components != null && module.Components.Any())
                                {
                                    var assessableComponents = module.Components.Where(c => c.Stage != ModuleStage.Teorica).ToList();
                                    var topLevelItems = assessableComponents.Where(c => c.ParentComponentId == null).ToList();

                                    @foreach (var item in topLevelItems)
                                    {
                                        var children = assessableComponents.Where(c => c.ParentComponentId == item.Id).ToList();

                                        @if (children.Any())
                                        {
                                            <div class="mb-3 mt-4">
                                                <div class="d-flex align-items-center mb-2">
                                                    <div style="width: 5px; height: 22px; background-color: #6A96A6; border-radius: 4px;" class="me-3"></div>
                                                    <h5 class="fw-bold mb-0" style="color: #1c4c5e;">@item.Title</h5>
                                                </div>
                                            </div>

                                            <div class="d-flex flex-column gap-2 mb-4">
                                                @foreach (var child in children)
                                                {
                                                    <div class="card border-0 bg-light" style="border-radius: 10px;">
                                                        <div class="card-body p-3 ms-4">
                                                            <div class="row align-items-center">
                                                                <div class="col-md-5 mb-2 mb-md-0 d-flex align-items-center">
                                                                    <i class="bi bi-arrow-return-right text-muted me-2 fs-5"></i>
                                                                    <h6 class="fw-semibold mb-0 text-dark" style="font-size: 0.95rem;">@child.Title</h6>
                                                                </div>
                                                                <div class="col-md-7">
                                                                    @RenderAssessmentButtons(child)
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="card border-0 bg-light mb-3" style="border-radius: 10px;">
                                                <div class="card-body p-3">
                                                    <div class="row align-items-center">
                                                        <div class="col-md-5 mb-2 mb-md-0 d-flex align-items-center">
                                                            <div style="width: 5px; height: 22px; background-color: #adb5bd; border-radius: 4px;" class="me-3"></div>
                                                            <h6 class="fw-bold mb-0 text-dark">@item.Title</h6>
                                                        </div>
                                                        <div class="col-md-7">
                                                            @RenderAssessmentButtons(item)
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                }
                            </div>
                        </div>
                    }
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int EnrollmentId { get; set; }

    private Enrollment? enrollment;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            enrollment = await Http.GetFromJsonAsync<Enrollment>($"api/Evaluation/enrollment/{EnrollmentId}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task EvaluateComponent(ModuleComponent component, ComponentStatus newStatus)
    {
        component.Status = newStatus;
        RecalculateProgress();

        var request = new
        {
            EnrollmentId = this.EnrollmentId,
            ModuleComponentId = component.Id,
            Status = newStatus
        };

        var response = await Http.PostAsJsonAsync("api/Evaluation", request);
        if (!response.IsSuccessStatusCode)
        {
            Console.WriteLine("Erro ao guardar avaliação.");
        }
    }

    private void GoBack()
    {
        if (enrollment != null && enrollment.PathwayId > 0)
        {
            Nav.NavigateTo($"/pathway/{enrollment.PathwayId}/students");
        }
        else
        {
            Nav.NavigateTo("/dashboard");
        }
    }

    private void RecalculateProgress()
    {
        if (enrollment?.Pathway?.Modules == null) return;

        int totalComponents = 0;
        int completedComponents = 0;

        foreach (var module in enrollment.Pathway.Modules)
        {
            if (module.Components != null)
            {
                // Ignora teóricas E ignora "Pais" que funcionam só de cabeçalho
                var assessableComponents = module.Components
                    .Where(c => c.Stage != ModuleStage.Teorica && !module.Components.Any(child => child.ParentComponentId == c.Id))
                    .ToList();

                totalComponents += assessableComponents.Count;

                completedComponents += assessableComponents.Count(c =>
                                    c.Status == ComponentStatus.AcimaDaMedia ||
                                    c.Status == ComponentStatus.Consistente);
            }
        }

        if (totalComponents > 0)
        {
            enrollment.ProgressPercentage = (int)((double)completedComponents / totalComponents * 100);
        }
    }

    // --- HELPER PARA RENDERIZAR OS BOTÕES SEM REPETIR CÓDIGO ---
    private RenderFragment RenderAssessmentButtons(ModuleComponent comp) => __builder =>
    {
        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-sm flex-grow-1 @(comp.Status == ComponentStatus.Inconsistente ? "btn-danger" : "btn-outline-danger")"
                    @onclick="() => EvaluateComponent(comp, ComponentStatus.Inconsistente)">
                Inconsistente
            </button>

            <button class="btn btn-sm flex-grow-1 @(comp.Status == ComponentStatus.AbaixoDaMedia ? "btn-warning text-dark" : "btn-outline-warning text-dark")"
                    @onclick="() => EvaluateComponent(comp, ComponentStatus.AbaixoDaMedia)">
                Abaixo da Média
            </button>

            <button class="btn btn-sm flex-grow-1 @(comp.Status == ComponentStatus.AcimaDaMedia ? "btn-warning bg-opacity-50 text-dark border-warning" : "btn-outline-secondary")"
                    style="@(comp.Status == ComponentStatus.AcimaDaMedia ? "background-color: #ffda6a;" : "")"
                    @onclick="() => EvaluateComponent(comp, ComponentStatus.AcimaDaMedia)">
                Acima da Média
            </button>

            <button class="btn btn-sm flex-grow-1 @(comp.Status == ComponentStatus.Consistente ? "btn-success shadow-sm fw-bold" : "btn-outline-success opacity-75")"
                    @onclick="() => EvaluateComponent(comp, ComponentStatus.Consistente)">
                @if (comp.Status == ComponentStatus.Consistente)
                {
                    <i class="bi bi-check2-circle me-1"></i>
                }
                Consistente
            </button>
        </div>
    };
}