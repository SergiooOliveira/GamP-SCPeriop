@page "/evaluate/{EnrollmentId:int}"
@using GamP_SCPeriop.Shared.Data
@using GamP_SCPeriop.Shared.Enum
@layout TopNavBarLayout
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 px-3">

            <button class="btn btn-link text-decoration-none text-muted p-0 mb-4 fw-semibold" @onclick="GoBack">
                <i class="bi bi-arrow-left me-2"></i> Voltar ao Dashboard
            </button>

            @if (isLoading)
            {
                <div class="d-flex justify-content-center mt-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (enrollment == null)
            {
                <div class="alert alert-danger shadow-sm border-0" style="border-radius: 15px;">
                    Inscrição não encontrada.
                </div>
            }
            else
            {
                <div class="card shadow-sm border-0 mb-5" style="border-radius: 20px; background-color: #6A96A6; color: white;">
                    <div class="card-body p-4 p-md-5">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge bg-white text-dark bg-opacity-25 px-3 py-2" style="border-radius: 10px;">Ficha de Avaliação</span>
                            <span class="fw-bold text-white fs-5">@enrollment.ProgressPercentage% Concluído</span>
                        </div>
                        <h3 class="fw-bold mb-1">@enrollment.Student?.DisplayShortName</h3>
                        <p class="mb-0 text-white-50">Percurso: @enrollment.Pathway?.Title</p>
                    </div>
                </div>

                @if (enrollment.Pathway?.Modules != null)
                {
                    @foreach (var module in enrollment.Pathway.Modules)
                    {
                        <div class="card shadow-sm border-0 mb-5" style="border-radius: 15px; border-left: 5px solid #2c3e50;">
                            <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                                <h4 class="fw-bold text-uppercase mb-0" style="color: #2c3e50; letter-spacing: 1px;">@module.Title</h4>
                            </div>

                            <div class="card-body p-4">
                                @if (module.Components != null && module.Components.Any())
                                {
                                    var practicalStages = module.Components
                                        .Where(c => c.Stage != ModuleStage.Teorica)
                                        .Select(c => c.Stage)
                                        .Distinct()
                                        .OrderBy(s => (int)s)
                                        .ToList();

                                    if (practicalStages.Any())
                                    {
                                        var currentStage = activeTabs.ContainsKey(module.Id) ? activeTabs[module.Id] : practicalStages.FirstOrDefault();

                                        <div class="d-flex w-100 mb-5 shadow-sm" style="height: 50px; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.1);">
                                            @foreach (var stage in practicalStages)
                                            {
                                                var isActive = currentStage == stage;
                                                var isChronological = chronologicalTabs.ContainsKey(module.Id) && chronologicalTabs[module.Id] == stage;

                                                <button class="btn border-0 rounded-0 flex-grow-1 position-relative d-flex align-items-center justify-content-center text-white p-0 shadow-none"
                                                        style="background-color: @GetStageColor(stage); transition: all 0.2s ease; opacity: @(isActive ? "1" : "0.4");"
                                                        @onclick="() => activeTabs[module.Id] = stage" title="@FormatStageName(stage)">

                                                    <div class="d-flex align-items-center px-2 text-truncate">
                                                        <i class="bi @(isActive ? "bi-check-circle-fill" : "bi-calendar-week") me-2"></i>
                                                        <span class="@(isActive ? "fw-bold" : "fw-medium") text-truncate" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                                                            @FormatStageName(stage)
                                                        </span>
                                                    </div>

                                                    @if (isChronological)
                                                    {
                                                        <span class="position-absolute top-0 start-50 translate-middle-x badge bg-dark bg-opacity-75 rounded-bottom shadow-sm"
                                                              style="font-size: 0.65rem; padding: 0.2rem 0.6rem; letter-spacing: 1px;">
                                                            SEMANA ATUAL
                                                        </span>
                                                    }
                                                </button>
                                            }
                                        </div>

                                        // 1. Encontra as datas da fase atual
                                        var timeline = module.StageTimelines?.FirstOrDefault(t => t.Stage == currentStage);
                                        double timeProgress = 0;

                                        if (timeline != null)
                                        {
                                            // 2. Calcula os dias e a percentagem
                                            var totalDays = (timeline.EndDate.Date - timeline.StartDate.Date).TotalDays;
                                            var passedDays = (DateTime.Now.Date - timeline.StartDate.Date).TotalDays;
                                            timeProgress = totalDays > 0 ? Math.Clamp((passedDays / totalDays) * 100, 0, 100) : (passedDays >= 0 ? 100 : 0);

                                            <div class="mb-4 px-1">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <small class="text-muted fw-bold" style="font-size: 0.75rem;">Progresso do Tempo Previsto</small>
                                                    <small class="fw-bold" style="color: @GetStageColor(currentStage); font-size: 0.8rem;">@((int)timeProgress)%</small>
                                                </div>
                                                <div class="progress shadow-sm" style="height: 8px; border-radius: 4px; background-color: #e9ecef;">
                                                    <div class="progress-bar" role="progressbar"
                                                         style="width: @((int)timeProgress)%; background-color: @GetStageColor(currentStage);"
                                                         aria-valuenow="@((int)timeProgress)" aria-valuemin="0" aria-valuemax="100"></div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="alert alert-warning py-2 px-3 mb-4 small shadow-sm border-0" style="border-radius: 8px;">
                                                <i class="bi bi-info-circle me-2"></i> As datas desta fase não vieram da Base de Dados.
                                            </div>
                                        }

                                        var assessableComponents = module.Components.Where(c => c.Stage == currentStage).ToList();
                                        var topLevelItems = assessableComponents.Where(c => c.ParentComponentId == null).ToList();

                                        foreach (var item in topLevelItems)
                                        {
                                            var children = assessableComponents.Where(c => c.ParentComponentId == item.Id).ToList();

                                            if (children.Any())
                                            {
                                                <div class="mb-3 mt-4">
                                                    <div class="d-flex align-items-center mb-2">
                                                        <div style="width: 5px; height: 22px; background-color: #6A96A6; border-radius: 4px;" class="me-3"></div>
                                                        <h5 class="fw-bold mb-0" style="color: #1c4c5e;">@item.Title</h5>
                                                    </div>
                                                </div>

                                                <div class="d-flex flex-column gap-2 mb-4">
                                                    @foreach (var child in children)
                                                    {
                                                        <div class="card border-0 bg-light" style="border-radius: 10px;">
                                                            <div class="card-body p-3 ms-4">
                                                                <div class="row align-items-center">
                                                                    <div class="col-md-5 mb-2 mb-md-0 d-flex align-items-center">
                                                                        <h6 class="fw-semibold mb-0 text-dark" style="font-size: 0.95rem;">@child.Title</h6>
                                                                    </div>
                                                                    <div class="col-md-7">
                                                                        @RenderAssessmentButtons(child)
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="card border-0 bg-light mb-3" style="border-radius: 10px;">
                                                    <div class="card-body p-3">
                                                        <div class="row align-items-center">
                                                            <div class="col-md-5 mb-2 mb-md-0 d-flex align-items-center">
                                                                <div style="width: 5px; height: 22px; background-color: #adb5bd; border-radius: 4px;" class="me-3"></div>
                                                                <h6 class="fw-bold mb-0 text-dark">@item.Title</h6>
                                                            </div>
                                                            <div class="col-md-7">
                                                                @RenderAssessmentButtons(item)
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    }
                                }
                            </div>
                        </div>
                    }
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int EnrollmentId { get; set; }
    private Enrollment? enrollment;
    private bool isLoading = true;
    private Dictionary<int, ModuleStage> activeTabs = new();
    private Dictionary<int, ModuleStage> chronologicalTabs = new(); // NOVO: Guarda a semana cronológica real

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            enrollment = await Http.GetFromJsonAsync<Enrollment>($"api/Evaluation/enrollment/{EnrollmentId}");

            if (enrollment != null)
            {
                InitializeTabs(); // Calcula a semana atual ao carregar
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void InitializeTabs()
    {
        if (enrollment?.Pathway?.Modules == null) return;

        var daysPassed = (DateTime.Now - enrollment.StartDate).TotalDays;
        var currentWeekIndex = Math.Max(0, (int)(daysPassed / 7));

        foreach (var module in enrollment.Pathway.Modules)
        {
            if (module.Components != null)
            {
                var practicalStages = module.Components
                    .Where(c => c.Stage != ModuleStage.Teorica)
                    .Select(c => c.Stage)
                    .Distinct()
                    .OrderBy(s => (int)s)
                    .ToList();

                if (practicalStages.Any())
                {
                    // Por defeito assume a primeira
                    ModuleStage actualStage = practicalStages.First();

                    // NOVA LÓGICA: Procurar nas datas reais (StageTimelines)
                    if (module.StageTimelines != null && module.StageTimelines.Any())
                    {
                        var today = DateTime.Now.Date;

                        // 1. Tenta encontrar a fase onde o 'hoje' encaixa
                        var currentTimeline = module.StageTimelines
                            .FirstOrDefault(t => today >= t.StartDate.Date && today <= t.EndDate.Date);

                        if (currentTimeline != null)
                        {
                            actualStage = currentTimeline.Stage;
                        }
                        else
                        {
                            // 2. Se já passou de todas as datas, tranca na última fase
                            var lastTimeline = module.StageTimelines.OrderBy(t => t.EndDate).LastOrDefault();
                            if (lastTimeline != null && today > lastTimeline.EndDate.Date)
                            {
                                actualStage = lastTimeline.Stage;
                            }
                        }
                    }

                    activeTabs[module.Id] = actualStage;        // Aba que abre
                    chronologicalTabs[module.Id] = actualStage; // Crachá SEMANA ATUAL
                }
            }
        }
    }

    // Helper para o texto dos botões (Transforma "PraticaSupervisionada" em "Prática Supervisionada")
    private string FormatStageName(ModuleStage stage)
    {
        return System.Text.RegularExpressions.Regex.Replace(stage.ToString(), "([A-Z])", " $1").Trim();
    }

    private async Task EvaluateComponent(ModuleComponent component, ComponentStatus newStatus)
    {
        component.Status = newStatus;
        RecalculateProgress();

        var request = new
        {
            EnrollmentId = this.EnrollmentId,
            ModuleComponentId = component.Id,
            Status = newStatus
        };

        var response = await Http.PostAsJsonAsync("api/Evaluation", request);
        if (!response.IsSuccessStatusCode)
        {
            Console.WriteLine("Erro ao guardar avaliação.");
        }
    }

    private void GoBack()
    {
        if (enrollment != null && enrollment.PathwayId > 0)
        {
            Nav.NavigateTo($"/pathway/{enrollment.PathwayId}/students");
        }
        else
        {
            Nav.NavigateTo("/dashboard");
        }
    }

    private void RecalculateProgress()
    {
        if (enrollment?.Pathway?.Modules == null) return;

        int totalComponents = 0;
        int completedComponents = 0;

        foreach (var module in enrollment.Pathway.Modules)
        {
            if (module.Components != null)
            {

                var assessableComponents = module.Components
                    .Where(c => c.Stage == ModuleStage.PraticaSupervisionada)
                    .Where(c => !module.Components.Any(child => child.ParentComponentId == c.Id))
                    .ToList();

                totalComponents += assessableComponents.Count;

                completedComponents += assessableComponents.Count(c =>
                                    c.Status == ComponentStatus.AcimaDaMedia ||
                                    c.Status == ComponentStatus.Consistente);
            }
        }

        if (totalComponents > 0)
        {
            enrollment.ProgressPercentage = (int)((double)completedComponents / totalComponents * 100);
        }
        else
        {
            enrollment.ProgressPercentage = 0;
        }
    }

    private bool IsTaskCompleted(ModuleComponent comp)
    {
        // A checklist aparece ligada se a avaliação for Consistente ou Acima da Média
        return comp.Status == ComponentStatus.Consistente || comp.Status == ComponentStatus.AcimaDaMedia;
    }

    private async Task ToggleChecklist(ModuleComponent comp, object? isChecked)
    {
        bool isCompleted = (bool)(isChecked ?? false);

        // Se marcou como feito, atribuímos a nota Consistente. 
        // Se desmarcou, voltamos ao estado 0 (assumindo que o 0 do teu Enum é o Pendente/Vazio).
        var newStatus = isCompleted ? ComponentStatus.Consistente : (ComponentStatus)0; 
        
        // Reutilizamos o teu método de gravação que já calcula o progresso e envia para a API
        await EvaluateComponent(comp, newStatus);
    }

    private string GetStageColor(ModuleStage stage)
    {
        return stage switch
        {
            ModuleStage.ObservacaoPassiva => "#6A96A6", // O teu Azul (Fase inicial)
            ModuleStage.ObservacaoParticipada => "#F4A261", // Laranja Suave (Transição)
            ModuleStage.PraticaAssistida => "#E76F51", // Laranja Escuro (Ação)
            ModuleStage.PraticaSupervisionada => "#2A9D8F", // Verde Teal (Avaliação Final)
            _ => "#6c757d"
        };
    }

    // --- HELPER PARA RENDERIZAR OS BOTÕES SEM REPETIR CÓDIGO ---
    private RenderFragment RenderAssessmentButtons(ModuleComponent comp) => __builder =>
    {
        @if (comp.Stage == ModuleStage.ObservacaoPassiva || comp.Stage == ModuleStage.ObservacaoParticipada)
        {
            <div class="d-flex justify-content-end">
                <input class="form-check-input" type="checkbox" 
                       style="width: 1.5rem; height: 1.5rem; cursor: pointer;"
                       checked="@IsTaskCompleted(comp)" 
                       @onchange="(e) => ToggleChecklist(comp, e.Value)" />
            </div>
        }
        else
        {
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-sm flex-grow-1 @(comp.Status == ComponentStatus.Inconsistente ? "btn-danger" : "btn-outline-danger")"
                @onclick="() => EvaluateComponent(comp, ComponentStatus.Inconsistente)">
                    Inconsistente
                </button>

                <button class="btn btn-sm flex-grow-1 @(comp.Status == ComponentStatus.AbaixoDaMedia ? "btn-warning text-dark" : "btn-outline-warning text-dark")"
                @onclick="() => EvaluateComponent(comp, ComponentStatus.AbaixoDaMedia)">
                    Abaixo da Média
                </button>

                <button class="btn btn-sm flex-grow-1 @(comp.Status == ComponentStatus.AcimaDaMedia ? "btn-warning bg-opacity-50 text-dark border-warning" : "btn-outline-secondary")"
                style="@(comp.Status == ComponentStatus.AcimaDaMedia ? "background-color: #ffda6a;" : "")"
                @onclick="() => EvaluateComponent(comp, ComponentStatus.AcimaDaMedia)">
                    Acima da Média
                </button>

                <button class="btn btn-sm flex-grow-1 @(comp.Status == ComponentStatus.Consistente ? "btn-success shadow-sm fw-bold" : "btn-outline-success opacity-75")"
                @onclick="() => EvaluateComponent(comp, ComponentStatus.Consistente)">
                    @if (comp.Status == ComponentStatus.Consistente)
                    {
                        <i class="bi bi-check2-circle me-1"></i>
                    }
                    Consistente
                </button>
            </div>
        }
    };
}