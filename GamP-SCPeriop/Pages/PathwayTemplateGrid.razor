@page "/templates"
@layout TopNavBarLayout
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@using GamP_SCPeriop.Shared.Data.Template

<div class="container-fluid">
    <!-- Cabeçalho e Pesquisa -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Modelos de Percurso</h3>

        <div class="d-flex gap-2">
            <!-- O @bind-value com bind-value:event="oninput" faz a pesquisa em tempo real -->
            <input type="text" class="form-control" placeholder="Pesquisar molde..."
                   @bind-value="SearchTerm" @bind-value:event="oninput" />

            <button class="btn btn-primary text-nowrap" @onclick="CreateNewTemplate">
                + Novo Molde
            </button>
        </div>
    </div>

    <!-- Grelha de Cartões -->
    @if (isLoading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">A carregar moldes...</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var template in FilteredTemplates)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@template.Title</h5>
                            <p class="card-text text-muted">@template.Description</p>
                        </div>
                        <div class="card-footer bg-transparent d-flex justify-content-end gap-2">
                            <!-- Botões de Ação do Cartão -->
                            <button class="btn btn-sm btn-outline-secondary">Editar</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTemplate(template.Id)">Apagar</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showCreateModal)
{
    <div class="modal-backdrop fade show" style="background-color: rgba(0,0,0,0.5);"></div>
    <div class="modal fade show d-block" tabindex="-1" @onclick="CloseCreateModal">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content border-0 shadow" style="border-radius: 20px;">

                <div class="modal-header border-0 pb-0 mt-4 d-flex flex-column align-items-center">
                    <button type="button" class="btn-close position-absolute top-0 end-0 m-3" @onclick="CloseCreateModal"></button>
                    <h4 class="fw-bold mb-0 text-dark">Novo Molde Base</h4>
                    <p class="text-muted small mb-2">Estrutura inicial do template</p>
                </div>

                <div class="modal-body px-4 pb-4 mt-2">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary small mb-1">Título do Molde</label>
                        <input class="form-control border-0 shadow-sm bg-light" style="border-radius: 10px; padding: 12px;" @bind="newTemplate.Title" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold text-secondary small mb-1">Descrição</label>
                        <textarea class="form-control border-0 shadow-sm bg-light" style="border-radius: 10px; padding: 12px; resize: none;" rows="2" @bind="newTemplate.Description"></textarea>
                    </div>

                    <button class="btn w-100 text-white fw-bold py-3 shadow-sm" style="border-radius: 10px; background-color: #6A96A6;"
                            @onclick="SaveNewTemplate" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        }
                        else
                        {
                            <span>Criar Molde</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;

    private List<PathwayTemplate> Templates = new();
    private string SearchTerm = string.Empty;

    // Variáveis de estado do modal
    private bool showCreateModal = false;
    private bool isSubmitting = false;
    private PathwayTemplate newTemplate = new();

    // Propriedade calculada: sempre que o ecrã desenha, filtra automaticamente
    private IEnumerable<PathwayTemplate> FilteredTemplates =>
        string.IsNullOrWhiteSpace(SearchTerm)
            ? Templates
            : Templates.Where(t => t.Title.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Vai buscar a lista de moldes à API
            var result = await Http.GetFromJsonAsync<List<PathwayTemplate>>("api/PathwayTemplate");

            if (result != null)
            {
                Templates = result;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar os templates: {ex.Message}");
        }
        finally
        {
            isLoading = false; // Desliga o loading aconteça o que acontecer
        }
    }

    private void CreateNewTemplate()
    {
        newTemplate = new PathwayTemplate(); // Limpa o formulário
        showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        showCreateModal = false;
    }

    // Função de gravação
    private async Task SaveNewTemplate()
    {
        if (string.IsNullOrWhiteSpace(newTemplate.Title)) return;

        isSubmitting = true;

        var response = await Http.PostAsJsonAsync("api/PathwayTemplate", newTemplate);

        if (response.IsSuccessStatusCode)
        {
            var createdTemplate = await response.Content.ReadFromJsonAsync<PathwayTemplate>();
            if (createdTemplate != null)
            {
                Templates.Add(createdTemplate); // Atualiza a grelha visualmente
                CloseCreateModal();
            }
        }
        else
        {
            Console.WriteLine("Erro ao criar o molde.");
        }

        isSubmitting = false;
    }

    private async Task DeleteTemplate(int id)
    {
        // 1. Pede confirmação ao utilizador
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Tem a certeza que deseja apagar este molde?");
        if (!confirmed) return;

        // 2. Chama a API para apagar
        var response = await Http.DeleteAsync($"api/PathwayTemplate/{id}");

        if (response.IsSuccessStatusCode)
        {
            // 3. Remove o cartão da lista visual sem precisar de fazer refresh à página
            var templateToRemove = Templates.FirstOrDefault(t => t.Id == id);
            if (templateToRemove != null)
            {
                Templates.Remove(templateToRemove);
            }
        }
        else
        {
            Console.WriteLine("Erro ao apagar o molde.");
        }
    }


}