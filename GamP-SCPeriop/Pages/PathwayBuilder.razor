@page "/supervisor/pathway-builder"
@layout TopNavBarLayout
@inject HttpClient Http
@using GamP_SCPeriop.Shared.Entity.Model
@using GamP_SCPeriop.Shared.Enum

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Construtor de Percurso (Pathway)</h2>

    @if (activePathway == null)
    {
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card shadow-sm p-4 border-0 h-100" style="border-radius: 15px; background-color: #f8f9fa;">
                    <h5 class="mb-3 fw-bold text-secondary"><i class="bi bi-folder2-open me-2"></i>Carregar Existente</h5>
                    <p class="text-muted small mb-3">Selecione um percurso já criado para continuar a editá-lo.</p>
                    
                    <div class="input-group">
                        <select class="form-select" @bind="selectedExistingPathwayId">
                            <option value="0" selected disabled>Selecione um percurso...</option>
                            @foreach (var p in existingPathways)
                            {
                                <option value="@p.PathwayId">@p.Title</option>
                            }
                        </select>
                        <button class="btn btn-secondary px-3" @onclick="LoadExistingPathway" disabled="@(selectedExistingPathwayId == 0)">
                            <i class="bi bi-cloud-download me-2"></i>Carregar
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm p-4 border-0 h-100" style="border-radius: 15px; background-color: #f8f9fa;">
                    <h5 class="mb-3 fw-bold text-primary"><i class="bi bi-plus-circle me-2"></i>Criar Novo Percurso</h5>
                    
                    <div class="mb-3">
                        <input @bind="pathwayDto.Title" class="form-control" placeholder="Título (Ex: Enfermagem Cirúrgica)" />
                    </div>
                    
                    <div class="row mb-3 g-2">
                        <div class="col-6">
                            <label class="form-label small text-muted mb-1">Mín. Passar (%)</label>
                            <input type="number" @bind="pathwayDto.MinimumPassScore" class="form-control form-control-sm" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted mb-1">Mín. Aprovação (%)</label>
                            <input type="number" @bind="pathwayDto.MinimumApprovalScore" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <button @onclick="CreatePathway" class="btn text-white fw-bold w-100" style="border-radius: 10px; background-color: #6A96A6; border: none;">
                        Criar e Iniciar
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-success d-flex justify-content-between align-items-center shadow-sm" style="border-radius: 10px; border-left: 5px solid #198754;">
            <div>
                <span class="text-muted small">Percurso Ativo:</span><br />
                <strong class="fs-5">@activePathway.Title</strong>
            </div>
            <div>
                @* <span class="badge bg-success fs-6 me-2">ID: @activePathway.Id</span> *@
                <button class="btn btn-sm btn-outline-success" @onclick="CloseActivePathway"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>

        <div class="mt-4 card shadow-sm p-4 border-0" style="border-radius: 15px;">
            <h5 class="mb-3 fw-bold text-primary">2. Gestão de Módulos</h5>
    
            @if (savedModules.Any())
            {
                <div class="list-group mb-4 shadow-sm" style="border-radius: 10px;">
                    @foreach (var mod in savedModules)
                    {
                        <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3"
                                @onclick="() => OpenModuleModal(mod)">
                            <span class="fw-bold text-dark">@mod.Title</span>
                            <i class="bi bi-pencil-square text-muted"></i>
                        </button>
                    }
                </div>
            }

            <div class="input-group shadow-sm" style="border-radius: 8px; overflow: hidden;">
                <input @bind="newModuleTitle" class="form-control border-0 p-3 bg-light" placeholder="Ex: Módulo 1 - Fundamentos" />
                <button @onclick="CreateModule" class="btn text-white fw-bold px-4" style="background-color: #6A96A6; border: none;">
                    Adicionar Módulo
                </button>
            </div>
        </div>
    }
</div>

@if (activeModalModule != null)
{
    <div class="modal-backdrop fade show" style="background-color: rgba(0,0,0,0.6); position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1040;"></div>
    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1055; overflow-y: auto;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow" style="border-radius: 15px; background-color: #f4f7f6;">
                
                <div class="modal-header border-bottom-0 pb-2 pt-4 px-4">
                    <h4 class="modal-title fw-bold text-primary">@activeModalModule.Title</h4>
                    <button type="button" class="btn-close" @onclick="CloseModuleModal"></button>
                </div>

                <div class="modal-body px-4">
                    @foreach (var stageInfo in stagesToRender)
                    {
                        <div class="card border-0 shadow-sm mb-4" style="border-radius: 10px;">
                            <div class="card-body p-4">
                                
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="fw-bold text-dark mb-0 fs-5"><i class="bi @stageInfo.Icon me-2 text-primary"></i>@stageInfo.Title</h6>
                                    
                                    @if (stageInfo.CopyFromStage.HasValue)
                                    {
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => CopyComponentsFromStage(activeModalModule.Id, stageInfo.Stage, stageInfo.CopyFromStage.Value)" disabled="@isCopying">
                                            <i class="bi bi-copy me-1"></i> Copiar Anterior
                                        </button>
                                    }
                                </div>

                                @if (activeModalModule.Components != null && activeModalModule.Components.Any(c => c.Stage == stageInfo.Stage))
                                {
                                    <div class="list-group mb-3">
                                        @foreach (var comp in activeModalModule.Components.Where(c => c.Stage == stageInfo.Stage))
                                        {
                                            <div class="list-group-item d-flex justify-content-between align-items-center bg-white border" style="border-radius: 8px; margin-bottom: 5px;">
                                                <div>
                                                    <i class="bi @(string.IsNullOrEmpty(comp.PdfFilePath) ? "bi-card-text text-secondary" : "bi-link-45deg text-success") me-2"></i>
                                                    <span class="fw-semibold text-dark">@comp.Title</span>
                                                    @if (!string.IsNullOrEmpty(comp.PdfFilePath))
                                                    {
                                                        <div class="text-muted small ms-4 mt-1" style="font-size: 0.8rem;">@comp.PdfFilePath</div>
                                                    }
                                                </div>
                                                <button class="btn btn-sm text-danger border-0" @onclick="() => DeleteComponent(comp.Id)">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                }

                                <div class="p-3 rounded" style="background-color: #f8f9fa; border: 1px dashed #ced4da;">
                                    <div class="mb-2">
                                        <input class="form-control form-control-sm border-0 shadow-sm" placeholder="Título (Ex: Manual de Ventilação, ou Critério de Avaliação)..." @bind="newComponentTitles[stageInfo.Stage]" />
                                    </div>
                                    <div class="mb-2">
                                        <input class="form-control form-control-sm border-0 shadow-sm" placeholder="URL ou Ficheiro (Opcional)..." @bind="newComponentFiles[stageInfo.Stage]" />
                                    </div>
                                    <div class="text-end">
                                        <button class="btn btn-sm text-white px-3" style="background-color: #6A96A6;" @onclick="() => AddComponentToStage(stageInfo.Stage)">
                                            <i class="bi bi-plus-lg me-1"></i> Adicionar
                                        </button>
                                    </div>
                                </div>

                            </div>
                        </div>
                    }
                </div>

                <div class="modal-footer border-top-0 d-flex justify-content-between px-4 pb-4">
                    <button type="button" class="btn btn-outline-danger shadow-sm" @onclick="DeleteActiveModule">
                        <i class="bi bi-trash3 me-2"></i>Eliminar Módulo Completo
                    </button>
                    <button type="button" class="btn btn-secondary px-4 shadow-sm" @onclick="CloseModuleModal">Concluído</button>
                </div>

            </div>
        </div>
    </div>
}


@code {
    private PathwayCreateDTO pathwayDto = new PathwayCreateDTO { MinimumPassScore = 50, MinimumApprovalScore = 75 };
    private Pathway? activePathway;
    private string newModuleTitle = string.Empty;
    private List<Module> savedModules = new();
    private Dictionary<string, string> stageInputs = new();
    private bool isCopying = false;

    // Load Existing Pathway Variables
    private List<PathwayTagDto> existingPathways = new();
    private int selectedExistingPathwayId = 0;

    // Modal Variables
    private ModuleComponent? componentToEdit;
    private bool isSavingModal = false;
    private Module? activeModalModule;
    private Dictionary<ModuleStage, string> newComponentTitles = new();
    private Dictionary<ModuleStage, string> newComponentFiles = new();

    private List<(ModuleStage Stage, string Title, string Icon, ModuleStage? CopyFromStage)> stagesToRender = new()
    {
        (ModuleStage.Teorica, "Componente Teórica", "bi-journal-text", null),
        (ModuleStage.ObservacaoPassiva, "Observação Passiva", "bi-eye", null),
        (ModuleStage.ObservacaoParticipada, "Observação Participada", "bi-people", ModuleStage.ObservacaoPassiva),
        (ModuleStage.PraticaAssistida, "Prática Assistida", "bi-person-gear", ModuleStage.ObservacaoParticipada),
        (ModuleStage.PraticaSupervisionada, "Prática Supervisionada", "bi-person-check", ModuleStage.PraticaAssistida)
    };

    protected override async Task OnInitializedAsync()
    {
        // Fetch the lightweight DTOs to populate the dropdown (Reusing the endpoint from the Student Management page!)
        existingPathways = await Http.GetFromJsonAsync<List<PathwayTagDto>>("api/Pathway/available-options") ?? new();
    }

    private async Task LoadExistingPathway()
    {
        if (selectedExistingPathwayId == 0) return;

        // Fetch the full pathway, including its modules and components
        var response = await Http.GetAsync($"api/Pathway/{selectedExistingPathwayId}");
        if (response.IsSuccessStatusCode)
        {
            activePathway = await response.Content.ReadFromJsonAsync<Pathway>();
            if (activePathway != null)
            {
                savedModules = activePathway.Modules ?? new List<Module>();

                // Initialize the input dictionaries for existing modules
                foreach (var mod in savedModules)
                {
                    foreach (var stage in stagesToRender)
                    {
                        stageInputs[$"{mod.Id}-{stage.Stage}"] = string.Empty;
                    }
                }
            }
        }
    }

    private void CloseActivePathway()
    {
        Console.WriteLine("Closing this pathway");
        // Returns the user to the "Select/Create" screen
        activePathway = null;
        savedModules.Clear();
        selectedExistingPathwayId = 0;
    }

    private async Task CreatePathway()
    {
        if (string.IsNullOrWhiteSpace(pathwayDto.Title)) return;
        var response = await Http.PostAsJsonAsync("api/Pathway", pathwayDto);
        if (response.IsSuccessStatusCode)
        {
            activePathway = await response.Content.ReadFromJsonAsync<Pathway>();
            // Re-fetch the dropdown list so the new pathway appears in it later
            existingPathways = await Http.GetFromJsonAsync<List<PathwayTagDto>>("api/Pathway/available-options") ?? new();
        }
    }

    private async Task CreateModule()
    {
        if (string.IsNullOrWhiteSpace(newModuleTitle) || activePathway == null) return;
        var dto = new ModuleCreateDTO { Title = newModuleTitle, PathwayId = activePathway.Id };
        var response = await Http.PostAsJsonAsync("api/Module", dto);

        if (response.IsSuccessStatusCode)
        {
            var savedMod = await response.Content.ReadFromJsonAsync<Module>();
            if (savedMod != null)
            {
                savedMod.Components = new List<ModuleComponent>();
                savedModules.Add(savedMod);
                foreach (var stage in stagesToRender) { stageInputs[$"{savedMod.Id}-{stage.Stage}"] = string.Empty; }
                newModuleTitle = string.Empty;
            }
        }
    }

    private async Task CreateComponent(int moduleId, ModuleStage stage)
    {
        var inputKey = $"{moduleId}-{stage}";
        if (!stageInputs.ContainsKey(inputKey) || string.IsNullOrWhiteSpace(stageInputs[inputKey])) return;

        var dto = new ModuleComponentCreateDTO { ModuleId = moduleId, Title = stageInputs[inputKey], Stage = stage, PdfFilePath = "" };
        var response = await Http.PostAsJsonAsync("api/ModuleComponent", dto);

        if (response.IsSuccessStatusCode)
        {
            var savedComp = await response.Content.ReadFromJsonAsync<ModuleComponent>();
            if (savedComp != null)
            {
                var targetModule = savedModules.First(m => m.Id == moduleId);
                targetModule.Components ??= new List<ModuleComponent>();
                targetModule.Components.Add(savedComp);
                stageInputs[inputKey] = string.Empty;
                StateHasChanged();
            }
        }
    }

    private async Task CopyComponentsFromStage(int moduleId, ModuleStage targetStage, ModuleStage sourceStage)
    {
        isCopying = true;
        var module = savedModules.First(m => m.Id == moduleId);
        var itemsToCopy = module.Components?.Where(c => c.Stage == sourceStage).ToList() ?? new();
        if (!itemsToCopy.Any()) { isCopying = false; return; }

        foreach (var item in itemsToCopy)
        {
            var dto = new ModuleComponentCreateDTO { ModuleId = moduleId, Title = item.Title, Stage = targetStage, PdfFilePath = item.PdfFilePath };
            var response = await Http.PostAsJsonAsync("api/ModuleComponent", dto);
            if (response.IsSuccessStatusCode)
            {
                var savedCopy = await response.Content.ReadFromJsonAsync<ModuleComponent>();
                if (savedCopy != null) module.Components!.Add(savedCopy);
            }
        }
        isCopying = false;
        StateHasChanged();
    }

    // --- MODAL LOGIC ---
    private void OpenComponentModal(int compId)
    {
        Console.WriteLine($"[DEBUG] Clicou no componente ID: {compId}");
    
        // Find the exact component securely using the ID
        componentToEdit = savedModules
            .SelectMany(m => m.Components ?? new List<ModuleComponent>())
            .FirstOrDefault(c => c.Id == compId);
        
        StateHasChanged();
    }

    private void CloseComponentModal()
    {
        componentToEdit = null;
    }

    private async Task SaveComponentEdits()
    {
        if (componentToEdit == null) return;
        isSavingModal = true;

        // Assumes you have an endpoint: [HttpPut("{id}")] in ModuleComponentController
        var response = await Http.PutAsJsonAsync($"api/ModuleComponent/{componentToEdit.Id}", componentToEdit);
        
        if (response.IsSuccessStatusCode)
        {
            CloseComponentModal();
            StateHasChanged(); // The UI updates automatically because componentToEdit references the object in our list!
        }
        else
        {
            Console.WriteLine("Erro ao guardar edições. Falta o HttpPut no servidor?");
        }
        
        isSavingModal = false;
    }

    private async Task DeleteComponent(int compId)
    {
        if (activeModalModule == null) return;
        
        // Assumes you have an endpoint: [HttpDelete("{id}")] in ModuleComponentController
        var response = await Http.DeleteAsync($"api/ModuleComponent/{compId}");
        if (response.IsSuccessStatusCode)
        {
            var compToRemove = activeModalModule.Components!.FirstOrDefault(c => c.Id == compId);
            if (compToRemove != null) activeModalModule.Components!.Remove(compToRemove);
            StateHasChanged();
        }
    }

    private void OpenModuleModal(Module mod)
    {
        activeModalModule = mod;
        activeModalModule.Components ??= new List<ModuleComponent>();

        // Initialize the empty text boxes for all 5 stages
        foreach (var stage in stagesToRender)
        {
            newComponentTitles[stage.Stage] = string.Empty;
            newComponentFiles[stage.Stage] = string.Empty;
        }
        
        StateHasChanged();
    }

    private void CloseModuleModal()
    {
        activeModalModule = null;
    }

    // --- ADD / DELETE COMPONENT LOGIC ---
    private async Task AddComponentToStage(ModuleStage stage)
    {
        if (activeModalModule == null || string.IsNullOrWhiteSpace(newComponentTitles[stage])) return;

        var dto = new ModuleComponentCreateDTO
        {
            ModuleId = activeModalModule.Id,
            Title = newComponentTitles[stage],
            Stage = stage,
            PdfFilePath = newComponentFiles.ContainsKey(stage) ? newComponentFiles[stage] : ""
        };

        var response = await Http.PostAsJsonAsync("api/ModuleComponent", dto);
        if (response.IsSuccessStatusCode)
        {
            var savedComp = await response.Content.ReadFromJsonAsync<ModuleComponent>();
            if (savedComp != null)
            {
                activeModalModule.Components!.Add(savedComp);
                
                // Clear the text boxes for this specific stage after saving
                newComponentTitles[stage] = string.Empty;
                newComponentFiles[stage] = string.Empty;
                
                StateHasChanged();
            }
        }
    }

    // --- DELETE WHOLE MODULE LOGIC ---
    private async Task DeleteActiveModule()
    {
        if (activeModalModule == null) return;

        // Assumes you have an endpoint: [HttpDelete("{id}")] in ModuleController
        var response = await Http.DeleteAsync($"api/Module/{activeModalModule.Id}");
        if (response.IsSuccessStatusCode)
        {
            savedModules.Remove(activeModalModule);
            CloseModuleModal();
            StateHasChanged();
        }
    }
}