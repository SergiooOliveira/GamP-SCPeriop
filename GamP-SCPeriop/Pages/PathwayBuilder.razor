@page "/supervisor/pathway-builder"
@inject HttpClient Http
@using GamP_SCPeriop.Shared.Entity.Model

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Construtor de Percurso (Pathway)</h2>

    @if (activePathway == null)
    {
        <div class="card shadow-sm p-4 border-0" style="border-radius: 15px; background-color: #f8f9fa;">
            <h5 class="mb-3 fw-bold text-primary">1. Detalhes do Novo Percurso</h5>
            
            <div class="mb-3">
                <label class="form-label fw-semibold">Título</label>
                <input @bind="pathwayDto.Title" class="form-control" placeholder="Ex: Enfermagem Cirúrgica" />
            </div>
            
            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Pontuação Mínima para Passar (%)</label>
                    <input type="number" @bind="pathwayDto.MinimumPassScore" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Pontuação Mínima para Aprovação (%)</label>
                    <input type="number" @bind="pathwayDto.MinimumApprovalScore" class="form-control" />
                </div>
            </div>

            <button @onclick="CreatePathway" class="btn text-white fw-bold px-4 py-2" style="border-radius: 10px; background-color: #6A96A6; border: none;">
                Criar Percurso e Continuar
            </button>
        </div>
    }
    else
    {
        <div class="alert alert-success d-flex justify-content-between align-items-center shadow-sm" style="border-radius: 10px; border-left: 5px solid #198754;">
            <div>
                <span class="text-muted small">Percurso Ativo:</span><br />
                <strong class="fs-5">@activePathway.Title</strong>
            </div>
            <span class="badge bg-success fs-6">ID: @activePathway.Id</span>
        </div>

        <div class="mt-4 card shadow-sm p-4 border-0" style="border-radius: 15px;">
            <h5 class="mb-3 fw-bold text-primary">2. Adicionar Módulos</h5>
            
            @if (savedModules.Any())
            {
                @if (savedModules.Any())
                {
                    <div class="mb-4">
                        @foreach (var mod in savedModules)
                        {
                            <div class="card shadow-sm mb-3 border-0" style="border-radius: 8px; border-left: 4px solid #6A96A6;">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="fw-bold fs-5 mb-0 text-primary">@mod.Title</h6>
                                    </div>
                                
                                    <div class="ms-3 ps-3 mt-3" style="border-left: 2px dashed #dee2e6;">
                                        @if (mod.Components != null && mod.Components.Any())
                                        {
                                            <ul class="list-unstyled mb-3">
                                                @foreach (var comp in mod.Components)
                                                {
                                                    <li class="mb-2 d-flex align-items-center gap-2 text-dark">
                                                        <i class="bi bi-file-earmark-text text-secondary"></i>
                                                        <span>@comp.Title</span>
                                                    </li>
                                                }
                                            </ul>
                                        }

                                        <div class="input-group input-group-sm w-75">
                                            <input @bind="newComponentTitles[mod.Id]" class="form-control bg-light border-0" placeholder="Nome do documento/quiz..." />
                                            <button @onclick="() => CreateComponent(mod.Id)" class="btn btn-outline-secondary fw-semibold">
                                                <i class="bi bi-plus-lg"></i> Adicionar Componente
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }

            <div class="input-group shadow-sm" style="border-radius: 8px; overflow: hidden;">
                <input @bind="newModuleTitle" class="form-control border-0 p-3" placeholder="Ex: Módulo 1 - Fundamentos" />
                <button @onclick="CreateModule" class="btn text-white fw-bold px-4" style="background-color: #6A96A6; border: none;">
                    Adicionar Módulo
                </button>
            </div>
        </div>
    }
</div>

@code {
    private PathwayCreateDTO pathwayDto = new PathwayCreateDTO { MinimumPassScore = 50, MinimumApprovalScore = 75 };
    
    // We use your real EF model here to capture the ID returned from the database
    private Pathway? activePathway;
    
    private string newModuleTitle = string.Empty;
    private List<Module> savedModules = new();

    // Tracks the input text for each specific module ID
    private Dictionary<int, string> newComponentTitles = new();

    private async Task CreatePathway()
    {
        // Prevent empty titles
        if (string.IsNullOrWhiteSpace(pathwayDto.Title)) return;

        var response = await Http.PostAsJsonAsync("api/Pathway", pathwayDto);
        
        if (response.IsSuccessStatusCode)
        {
            // Capture the saved Pathway so the UI flips to Phase 2
            activePathway = await response.Content.ReadFromJsonAsync<Pathway>();
        }
        else
        {
            Console.WriteLine("Erro ao criar Pathway. Verifique o Network tab.");
        }
    }

    private async Task CreateModule()
    {
        // Don't save if it's empty or we don't have a Pathway yet
        if (string.IsNullOrWhiteSpace(newModuleTitle) || activePathway == null) return;

        var dto = new ModuleCreateDTO
        {
            Title = newModuleTitle,
            PathwayId = activePathway.Id // Snapping it to our baseplate
        };

        // Make sure this matches your actual ModuleController route!
        var response = await Http.PostAsJsonAsync("api/Module", dto);

        if (response.IsSuccessStatusCode)
        {
            var savedMod = await response.Content.ReadFromJsonAsync<Module>();
            if (savedMod != null)
            {
                savedModules.Add(savedMod);    // Add it to the screen
                newComponentTitles[savedMod.Id] = string.Empty;
                newModuleTitle = string.Empty; // Clear the input box
            }
        }
    }

    private async Task CreateComponent(int moduleId)
    {
        Console.WriteLine($"[DEBUG] Clicou para adicionar no Módulo {moduleId}");

        if (!newComponentTitles.ContainsKey(moduleId))
        {
            Console.WriteLine($"[ERRO] O Dicionário não tem o ID {moduleId}. Faltou inicializar?");
            return;
        }

        if (string.IsNullOrWhiteSpace(newComponentTitles[moduleId]))
        {
            Console.WriteLine("[ERRO] O texto do componente está vazio!");
            return;
        }

        var dto = new ModuleComponentCreateDTO
        {
            Title = newComponentTitles[moduleId],
            ModuleId = moduleId,
            PdfFilePath = ""
        };

        Console.WriteLine($"[DEBUG] Enviando para a API: {dto.Title}");
        var response = await Http.PostAsJsonAsync("api/ModuleComponent", dto);

        if (response.IsSuccessStatusCode)
        {
            Console.WriteLine("[DEBUG] API retornou 200 OK!");
            var savedComp = await response.Content.ReadFromJsonAsync<ModuleComponent>();
            if (savedComp != null)
            {
                var targetModule = savedModules.First(m => m.Id == moduleId);
                targetModule.Components ??= new List<ModuleComponent>();
                targetModule.Components.Add(savedComp);

                newComponentTitles[moduleId] = string.Empty;
                
                // Força o Blazor a atualizar a tela
                StateHasChanged();
            }
        }
        else
        {
            Console.WriteLine($"[ERRO DA API] Falhou com o status: {response.StatusCode}");
        }
    }
}