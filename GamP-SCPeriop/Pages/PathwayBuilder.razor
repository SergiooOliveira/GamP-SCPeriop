    // --- NOVA GESTÃO DE DATAS (TIMELINES) ---
    private List<ModuleStage> GetTimelineStages()
    {
        return stagesToRender
            .Where(s => s.Stage != ModuleStage.Teorica)
            .Select(s => s.Stage)
            .ToList();
    }

    private ModuleStageTimeline GetOrCreateTimeline(Module mod, ModuleStage stage)
    {
        mod.StageTimelines ??= new List<ModuleStageTimeline>();
        var timeline = mod.StageTimelines.FirstOrDefault(t => t.Stage == stage);

        if (timeline == null)
        {
            var defaultStart = DateTime.Today;
            var timelineStages = GetTimelineStages();
            var currentIndex = timelineStages.IndexOf(stage);

            // Se não for a primeira etapa (ex: não for a Observação Passiva)
            if (currentIndex > 0)
            {
                var prevStage = timelineStages[currentIndex - 1];
                var prevTimeline = mod.StageTimelines.FirstOrDefault(t => t.Stage == prevStage);
                if (prevTimeline != null) defaultStart = prevTimeline.EndDate.AddDays(1);
            }

            timeline = new ModuleStageTimeline
            {
                ModuleId = mod.Id,
                Stage = stage,
                StartDate = defaultStart,
                EndDate = defaultStart.AddDays(7)
            };
            mod.StageTimelines.Add(timeline);
        }
        return timeline;
    }

    private async Task UpdateStartDate(Module mod, ModuleStage stage, ChangeEventArgs e)
    {
        try
        {
            if (DateTime.TryParse(e.Value?.ToString(), out DateTime newStart))
            {
                var timeline = GetOrCreateTimeline(mod, stage);

                // 1. Descobre a duração antiga
                var oldDuration = timeline.EndDate - timeline.StartDate;
                if (oldDuration.TotalDays < 0) oldDuration = TimeSpan.FromDays(7);

                // 2. Aplica as novas datas arrastando o bloco inteiro
                timeline.StartDate = newStart;
                timeline.EndDate = newStart.Add(oldDuration);

                // 3. Empurra as fases seguintes visualmente
                RecalculateStageDatesLocal(mod, stage);

                // 4. Tenta gravar (se falhar, não congela a UI)
                await Http.PutAsJsonAsync($"api/Module/{mod.Id}", mod);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao atualizar Início: {ex.Message}");
        }
    }

    private async Task UpdateEndDate(Module mod, ModuleStage stage, ChangeEventArgs e)
    {
        try
        {
            if (DateTime.TryParse(e.Value?.ToString(), out DateTime newEnd))
            {
                var timeline = GetOrCreateTimeline(mod, stage);

                // Previne que o Fim seja antes do Início
                if (newEnd < timeline.StartDate) newEnd = timeline.StartDate.AddDays(1);

                timeline.EndDate = newEnd;

                RecalculateStageDatesLocal(mod, stage);
                await Http.PutAsJsonAsync($"api/Module/{mod.Id}", mod);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao atualizar Fim: {ex.Message}");
        }
    }

    private void RecalculateStageDatesLocal(Module mod, ModuleStage changedStage)
    {
        var timelineStages = GetTimelineStages();
        var startIndex = timelineStages.IndexOf(changedStage);

        if (startIndex != -1)
        {
            for (int i = startIndex + 1; i < timelineStages.Count; i++)
            {
                var previousTimeline = GetOrCreateTimeline(mod, timelineStages[i - 1]);
                var currentTimeline = GetOrCreateTimeline(mod, timelineStages[i]);

                var currentDuration = currentTimeline.EndDate - currentTimeline.StartDate;
                if (currentDuration.TotalDays < 0) currentDuration = TimeSpan.FromDays(7);

                currentTimeline.StartDate = previousTimeline.EndDate.AddDays(1);
                currentTimeline.EndDate = currentTimeline.StartDate.Add(currentDuration);
            }
        }

        StateHasChanged();
    }

    // --- LÓGICA DE MODAL E PARÂMETROS MANTÉM-SE IGUAL ---
    private void OpenStageModal(Module mod, (ModuleStage Stage, string Title, string Icon, ModuleStage? CopyFromStage) stageInfo)
    {
        activeModalModule = mod;
        activeModalStage = stageInfo;
        ResetForm();
        CancelInlineEdit();
        StateHasChanged();
    }

    private void CloseStageModal()
    {
        activeModalModule = null;
        activeModalStage = null;
        CancelInlineEdit();
    }

    private void ResetForm()
    {
        if (activeModalModule != null && activeModalStage.HasValue)
        {
            componentToEdit = new ModuleComponent
            {
                Id = 0,
                ModuleId = activeModalModule.Id,
                Stage = activeModalStage.Value.Stage,
                Title = string.Empty,
                Description = string.Empty,
                PdfFilePath = string.Empty
            };
        }
        drafts = new List<DraftParent> { new DraftParent() };
    }

    private void StartInlineEdit(ModuleComponent comp)
    {
        if (activeModalStage?.Stage == ModuleStage.Teorica)
        {
            EditComponent(comp);
        }
        else
        {
            inlineEditId = comp.Id;
            inlineEditTitle = comp.Title;
            inlineNewChildren = new List<DraftChild> { new DraftChild() };
        }
    }

    private void CancelInlineEdit()
    {
        inlineEditId = null;
        inlineNewChildren.Clear();
    }

    private void CheckInlineChildrenState()
    {
        if (!string.IsNullOrWhiteSpace(inlineNewChildren.Last().Text))
            inlineNewChildren.Add(new DraftChild());
        else if (inlineNewChildren.Count > 1 && string.IsNullOrWhiteSpace(inlineNewChildren[^2].Text))
            inlineNewChildren.RemoveAt(inlineNewChildren.Count - 2);
    }

    private async Task SaveInlineEdit(ModuleComponent comp)
    {
        if (string.IsNullOrWhiteSpace(inlineEditTitle)) return;
        comp.Title = inlineEditTitle;
        var response = await Http.PutAsJsonAsync($"api/ModuleComponent/{comp.Id}", comp);

        if (response.IsSuccessStatusCode)
        {
            if (comp.ParentComponentId == null && activeModalModule != null && activeModalStage.HasValue)
            {
                foreach (var childDraft in inlineNewChildren.Where(c => !string.IsNullOrWhiteSpace(c.Text)))
                {
                    var newChildDto = new ModuleComponentCreateDTO
                    {
                        ModuleId = activeModalModule.Id,
                        Title = childDraft.Text,
                        Stage = activeModalStage.Value.Stage,
                        ParentComponentId = comp.Id
                    };
                    var childResponse = await Http.PostAsJsonAsync("api/ModuleComponent", newChildDto);
                    if (childResponse.IsSuccessStatusCode)
                    {
                        var savedChild = await childResponse.Content.ReadFromJsonAsync<ModuleComponent>();
                        if (savedChild != null) activeModalModule.Components!.Add(savedChild);
                    }
                }
            }

            inlineEditId = null;
            inlineNewChildren.Clear();
            StateHasChanged();
        }
    }

    private void EditComponent(ModuleComponent comp)
    {
        componentToEdit = new ModuleComponent
        {
            Id = comp.Id,
            ModuleId = comp.ModuleId,
            Stage = comp.Stage,
            Title = comp.Title,
            Description = comp.Description,
            PdfFilePath = comp.PdfFilePath
        };
    }

    private async Task SaveComponent()
    {
        if (string.IsNullOrWhiteSpace(componentToEdit.Title) || activeModalModule == null) return;
        isSavingModal = true;

        if (componentToEdit.Id == 0)
        {
            var dto = new ModuleComponentCreateDTO
            {
                ModuleId = componentToEdit.ModuleId,
                Title = componentToEdit.Title,
                Description = componentToEdit.Description,
                Stage = componentToEdit.Stage,
                PdfFilePath = componentToEdit.PdfFilePath
            };
            var response = await Http.PostAsJsonAsync("api/ModuleComponent", dto);
            if (response.IsSuccessStatusCode)
            {
                var savedComp = await response.Content.ReadFromJsonAsync<ModuleComponent>();
                if (savedComp != null)
                {
                    activeModalModule.Components ??= new List<ModuleComponent>();
                    activeModalModule.Components.Add(savedComp);
                }
            }
        }
        else
        {
            var response = await Http.PutAsJsonAsync($"api/ModuleComponent/{componentToEdit.Id}", componentToEdit);
            if (response.IsSuccessStatusCode)
            {
                var existing = activeModalModule.Components!.First(c => c.Id == componentToEdit.Id);
                existing.Title = componentToEdit.Title;
                existing.Description = componentToEdit.Description;
                existing.PdfFilePath = componentToEdit.PdfFilePath;
            }
        }

        isSavingModal = false;
        ResetForm();
        StateHasChanged();
    }

    private async Task DeleteComponent(int compId)
    {
        if (activeModalModule == null) return;
        var response = await Http.DeleteAsync($"api/ModuleComponent/{compId}");
        if (response.IsSuccessStatusCode)
        {
            var compToRemove = activeModalModule.Components!.FirstOrDefault(c => c.Id == compId);
            if (compToRemove != null) activeModalModule.Components!.Remove(compToRemove);
            StateHasChanged();
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        isUploading = true;
        StateHasChanged();

        var file = e.File;
        long maxAllowedSize = 10 * 1024 * 1024;
        try
        {
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);

            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/files/upload", content);
            if (response.IsSuccessStatusCode)
            {
                var secureUrl = await response.Content.ReadAsStringAsync();
                componentToEdit.PdfFilePath = secureUrl;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro: {ex.Message}");
        }

        isUploading = false;
        StateHasChanged();
    }

    private async Task CopyComponents()
    {
        if (activeModalModule == null || !activeModalStage.HasValue || !activeModalStage.Value.CopyFromStage.HasValue) return;
        isCopying = true;
        StateHasChanged();

        var sourceStage = activeModalStage.Value.CopyFromStage.Value;
        var targetStage = activeModalStage.Value.Stage;
        var allSourceComponents = activeModalModule.Components?.Where(c => c.Stage == sourceStage).ToList() ?? new();

        var idMapping = new Dictionary<int, int>();
        var parentsToCopy = allSourceComponents.Where(c => c.ParentComponentId == null).ToList();
        foreach (var parent in parentsToCopy)
        {
            var dto = new ModuleComponentCreateDTO
            {
                ModuleId = activeModalModule.Id,
                Title = parent.Title,
                Stage = targetStage,
                PdfFilePath = parent.PdfFilePath
            };
            var response = await Http.PostAsJsonAsync("api/ModuleComponent", dto);
            if (response.IsSuccessStatusCode)
            {
                var savedParent = await response.Content.ReadFromJsonAsync<ModuleComponent>();
                if (savedParent != null)
                {
                    activeModalModule.Components!.Add(savedParent);
                    idMapping[parent.Id] = savedParent.Id;
                }
            }
        }

        var childrenToCopy = allSourceComponents.Where(c => c.ParentComponentId != null).ToList();
        foreach (var child in childrenToCopy)
        {
            if (child.ParentComponentId.HasValue && idMapping.ContainsKey(child.ParentComponentId.Value))
            {
                var dto = new ModuleComponentCreateDTO
                {
                    ModuleId = activeModalModule.Id,
                    Title = child.Title,
                    Stage = targetStage,
                    PdfFilePath = child.PdfFilePath,
                    ParentComponentId = idMapping[child.ParentComponentId.Value]
                };
                var response = await Http.PostAsJsonAsync("api/ModuleComponent", dto);
                if (response.IsSuccessStatusCode)
                {
                    var savedChild = await response.Content.ReadFromJsonAsync<ModuleComponent>();
                    if (savedChild != null) activeModalModule.Components!.Add(savedChild);
                }
            }
        }

        isCopying = false;
        StateHasChanged();
    }

    private void CheckListState(DraftParent currentParent)
    {
        if (!string.IsNullOrWhiteSpace(drafts.Last().Text)) drafts.Add(new DraftParent());
        else if (drafts.Count > 1 && string.IsNullOrWhiteSpace(drafts[^2].Text))
        {
            if (!drafts[^2].Children.Any(f => !string.IsNullOrWhiteSpace(f.Text))) drafts.RemoveAt(drafts.Count - 2);
        }

        if (!string.IsNullOrWhiteSpace(currentParent.Children.Last().Text)) currentParent.Children.Add(new DraftChild());
        else if (currentParent.Children.Count > 1 && string.IsNullOrWhiteSpace(currentParent.Children[^2].Text))
        {
            currentParent.Children.RemoveAt(currentParent.Children.Count - 2);
        }
    }

    private async Task SaveRapidStructure()
    {
        if (activeModalModule == null || !activeModalStage.HasValue) return;
        isSavingModal = true;

        foreach (var parent in drafts.Where(p => !string.IsNullOrWhiteSpace(p.Text)))
        {
            var dtoParent = new ModuleComponentCreateDTO
            {
                ModuleId = activeModalModule.Id,
                Title = parent.Text,
                Stage = activeModalStage.Value.Stage
            };

            var responseParent = await Http.PostAsJsonAsync("api/ModuleComponent", dtoParent);
            if (responseParent.IsSuccessStatusCode)
            {
                var savedParent = await responseParent.Content.ReadFromJsonAsync<ModuleComponent>();
                if (savedParent != null)
                {
                    activeModalModule.Components ??= new List<ModuleComponent>();
                    activeModalModule.Components.Add(savedParent);

                    foreach (var child in parent.Children.Where(f => !string.IsNullOrWhiteSpace(f.Text)))
                    {
                        var dtoChild = new ModuleComponentCreateDTO
                        {
                            ModuleId = activeModalModule.Id,
                            Title = child.Text,
                            Stage = activeModalStage.Value.Stage,
                            ParentComponentId = savedParent.Id
                        };
                        var responseChild = await Http.PostAsJsonAsync("api/ModuleComponent", dtoChild);
                        if (responseChild.IsSuccessStatusCode)
                        {
                            var savedChild = await responseChild.Content.ReadFromJsonAsync<ModuleComponent>();
                            if (savedChild != null) activeModalModule.Components.Add(savedChild);
                        }
                    }
                }
            }
        }

        isSavingModal = false;
        ResetForm();
        StateHasChanged();
    }

    // --- MAGIA DOS PESOS E PERCENTAGENS ---
    private int GetModulePercentage(Module mod)
    {
        if (savedModules == null || !savedModules.Any()) return 0;
        // Soma os pesos de todos os módulos deste percurso (garantindo que valem pelo menos 1)
        var total = savedModules.Sum(m => Math.Max(1, m.Weight));
        return (int)Math.Round((double)Math.Max(1, mod.Weight) / total * 100);
    }

    private int GetComponentPercentage(ModuleComponent comp)
    {
        if (activeModalModule?.Components == null) return 0;
        // Compara o peso com os irmãos do mesmo nível e da mesma fase
        var peers = activeModalModule.Components
            .Where(c => c.Stage == comp.Stage && c.ParentComponentId == comp.ParentComponentId)
            .ToList();

        var total = peers.Sum(c => Math.Max(1, c.Weight));
        if (total == 0) return 0;
        return (int)Math.Round((double)Math.Max(1, comp.Weight) / total * 100);
    }

    private async Task SaveModuleWeight(Module mod)
    {
        if (mod.Weight < 1) mod.Weight = 1;
        if (mod.Weight > 10) mod.Weight = 10; // Impede que ultrapassem o limite

        await Http.PutAsJsonAsync($"api/Module/{mod.Id}", mod);
        StateHasChanged();
    }

    private async Task SaveComponentWeight(ModuleComponent comp)
    {
        if (comp.Weight < 1) comp.Weight = 1;
        if (comp.Weight > 10) comp.Weight = 10; // Impede que ultrapassem o limite

        await Http.PutAsJsonAsync($"api/ModuleComponent/{comp.Id}", comp);
        StateHasChanged();
    }
