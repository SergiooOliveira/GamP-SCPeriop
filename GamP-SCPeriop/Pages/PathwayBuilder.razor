@page "/supervisor/pathway-builder"
@page "/supervisor/pathway-builder/{PathwayIdToLoad:int}"
@layout TopNavBarLayout
@inject HttpClient Http
@inject NavigationManager Nav
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using GamP_SCPeriop.Shared.Entity.Model
@using GamP_SCPeriop.Shared.Enum
@using GamP_SCPeriop.Shared.Data

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Construtor de Percurso (Pathway)</h2>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center mt-5">
            <div class="spinner-border" style="color: #6A96A6;" role="status">
                <span class="visually-hidden">A carregar...</span>
            </div>
        </div>
    }
    else if (activePathway == null)
    {
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card shadow-sm p-4 border-0 h-100" style="border-radius: 15px; background-color: #f8f9fa;">
                    <h5 class="mb-3 fw-bold text-secondary"><i class="bi bi-folder2-open me-2"></i>Carregar Existente</h5>
                    <p class="text-muted small mb-3">Selecione um percurso já criado para continuar a editá-lo.</p>

                    <div class="input-group">
                        <select class="form-select" @bind="selectedExistingPathwayId">
                            <option value="0" selected disabled>Selecione um percurso...</option>
                            @foreach (var p in existingPathways)
                            {
                                <option value="@p.PathwayId">@p.Title</option>
                            }
                        </select>
                        <button class="btn btn-secondary px-3" @onclick="LoadExistingPathway" disabled="@(selectedExistingPathwayId == 0)">
                            <i class="bi bi-cloud-download me-2"></i>Carregar
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm p-4 border-0 h-100" style="border-radius: 15px; background-color: #f8f9fa;">
                    <h5 class="mb-3 fw-bold text-primary"><i class="bi bi-plus-circle me-2"></i>Criar Novo Percurso</h5>

                    <div class="mb-3">
                        <input @bind="pathwayDto.Title" class="form-control" placeholder="Título (Ex: Enfermagem Cirúrgica)" />
                    </div>

                    <div class="row mb-3 g-2">
                        <div class="col-6">
                            <label class="form-label small text-muted mb-1">Mín. Passar (%)</label>
                            <input type="number" @bind="pathwayDto.MinimumPassScore" class="form-control form-control-sm" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted mb-1">Mín. Aprovação (%)</label>
                            <input type="number" @bind="pathwayDto.MinimumApprovalScore" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <button @onclick="CreatePathway" class="btn text-white fw-bold w-100" style="border-radius: 10px; background-color: #6A96A6; border: none;">
                        Criar e Iniciar
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-success d-flex justify-content-between align-items-center shadow-sm" style="border-radius: 10px; border-left: 5px solid #198754;">
            <div>
                <span class="text-muted small">Percurso Ativo:</span><br />
                <strong class="fs-5">@activePathway.Title</strong>
            </div>
            <div>
                <span class="badge bg-success fs-6 me-2">ID: @activePathway.Id</span>
                <button class="btn btn-sm btn-outline-success" @onclick="CloseActivePathway"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>

        <div class="mt-4 card shadow-sm p-4 border-0" style="border-radius: 15px;">
            <h5 class="mb-3 fw-bold text-primary">2. Gestão de Módulos</h5>

            @if (savedModules.Any())
            {
                <div class="mb-4">
                    @foreach (var mod in savedModules)
                    {
                        var isExpanded = expandedModuleId == mod.Id;

                        <div class="card border-0 shadow-sm mb-3" style="border-radius: 10px; overflow: hidden;">

                            <div class="card-header bg-white border-0 p-0 d-flex align-items-center pe-4">
                                <button class="btn btn-link text-decoration-none fw-bold text-dark text-start flex-grow-1 p-3 px-4 shadow-none"
                                        type="button"
                                        @onclick="() => ToggleModule(mod.Id)">
                                    <i class="bi bi-folder2-open text-primary me-3 fs-5"></i> @mod.Title
                                </button>

                                <div class="d-flex align-items-center gap-2 border-end pe-3" @onclick:stopPropagation="true" title="Peso do módulo na nota final">
                                    <small class="text-muted fw-bold">Peso:</small>
                                    <input type="number" class="form-control form-control-sm text-center" style="width: 60px;" min="1" max="10"
                                           @bind="mod.Weight" @bind:after="() => SaveModuleWeight(mod)" />
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25" style="width: 48px;">@GetModulePercentage(mod)%</span>
                                </div>

                                <div class="d-flex align-items-center gap-3">
                                    <button class="btn btn-sm text-danger border-0 p-1 shadow-none"
                                            @onclick="() => DeleteActiveModule(mod.Id)"
                                            @onclick:stopPropagation="true"
                                            title="Eliminar Módulo Completo">
                                        <i class="bi bi-trash3 fs-5"></i>
                                    </button>

                                    <i class="bi @(isExpanded ? "bi-chevron-up" : "bi-chevron-down") text-muted"
                                       style="cursor: pointer;"
                                       @onclick="() => ToggleModule(mod.Id)"></i>
                                </div>
                            </div>

                            @if (isExpanded)
                            {
                                <div class="card-body p-0 border-top">
                                    <div class="list-group list-group-flush">
                                        @foreach (var stageInfo in stagesToRender)
                                        {
                                            var count = mod.Components?.Count(c => c.Stage == stageInfo.Stage) ?? 0;
                                            // APAGUEI A PRIMEIRA DECLARAÇÃO DA TIMELINE AQUI

                                            <div class="list-group-item d-flex flex-column border-0 border-bottom p-0" style="background-color: #f8f9fa;">
                                                <div class="d-flex justify-content-between align-items-center px-4 py-3">

                                                    <button type="button" class="btn btn-link text-decoration-none p-0 d-flex align-items-center flex-grow-1 text-start shadow-none"
                                                            @onclick="() => OpenStageModal(mod, stageInfo)">
                                                        <i class="bi @stageInfo.Icon me-3 text-secondary fs-5"></i>
                                                        <span class="fw-semibold text-dark">@stageInfo.Title</span>
                                                    </button>

                                                    <div class="d-flex align-items-center gap-3">

                                                        @if (stageInfo.Stage != ModuleStage.Teorica)
                                                        {
                                                            // A TIMELINE AGORA SÓ NASCE AQUI, SE NÃO FOR TEÓRICA
                                                            var timeline = GetOrCreateTimeline(mod, stageInfo.Stage);

                                                            <div class="d-flex align-items-center gap-2 me-3" @onclick:stopPropagation="true">
                                                                <small class="text-muted fw-bold" style="font-size: 0.7rem;">Início:</small>
                                                                <input type="date" class="form-control form-control-sm text-center"
                                                                       style="width: 120px; font-size: 0.8rem;"
                                                                       value="@timeline.StartDate.ToString("yyyy-MM-dd")"
                                                                       @onchange="(e) => UpdateStartDate(mod, stageInfo.Stage, e)" />

                                                                <small class="text-muted fw-bold ms-1" style="font-size: 0.7rem;">Fim:</small>
                                                                <input type="date" class="form-control form-control-sm text-center"
                                                                       style="width: 120px; font-size: 0.8rem;"
                                                                       value="@timeline.EndDate.ToString("yyyy-MM-dd")"
                                                                       @onchange="(e) => UpdateEndDate(mod, stageInfo.Stage, e)" />
                                                            </div>
                                                        }

                                                        @if (count > 0)
                                                        {
                                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1 border border-success border-opacity-25">@count itens</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-light text-muted border rounded-pill px-3 py-1">Vazio</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            <div class="input-group shadow-sm" style="border-radius: 8px; overflow: hidden;">
                <input @bind="newModuleTitle" class="form-control border-0 p-3 bg-light" placeholder="Ex: Módulo 1 - Fundamentos" />
                <button @onclick="CreateModule" class="btn text-white fw-bold px-4" style="background-color: #6A96A6; border: none;">
                    Adicionar Módulo
                </button>
            </div>
        </div>
    }
</div>

@if (activeModalModule != null && activeModalStage.HasValue)
{
    <div class="modal-backdrop fade show" style="background-color: rgba(0,0,0,0.6); position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1040;"></div>
    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1055;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow" style="border-radius: 15px; background-color: #f4f7f6;">

                <div class="modal-header border-bottom-0 pb-2 pt-4 px-4 bg-white" style="border-radius: 15px 15px 0 0;">
                    <div>
                        <span class="badge bg-secondary bg-opacity-10 text-secondary border mb-2">@activeModalModule.Title</span>
                        <h4 class="modal-title fw-bold text-primary"><i class="bi @activeModalStage.Value.Icon me-2"></i>@activeModalStage.Value.Title</h4>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseStageModal"></button>
                </div>

                <div class="modal-body px-4 py-4">

                    <div class="d-flex justify-content-between align-items-end mb-3">
                        <h6 class="fw-bold text-secondary text-uppercase small mb-0">Componentes Atuais</h6>

                        @if (activeModalStage.Value.CopyFromStage.HasValue)
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="CopyComponents" disabled="@isCopying">
                                @if (isCopying)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                else
                                {

                                    <i class="bi bi-copy me-1"></i>
                                }
                                Copiar da Fase Anterior
                            </button>
                        }
                    </div>

                    @if (activeModalModule.Components != null && activeModalModule.Components.Any(c => c.Stage == activeModalStage.Value.Stage))
                    {
                        <div class="list-group mb-4 shadow-sm" style="border-radius: 8px;">
                            @{
                                var stageComponents = activeModalModule.Components.Where(c => c.Stage == activeModalStage.Value.Stage).ToList();
                                var topLevel = stageComponents.Where(c => c.ParentComponentId == null).ToList();
                            }

                            @foreach (var comp in topLevel)
                            {
                                var children = stageComponents.Where(c => c.ParentComponentId == comp.Id).ToList();

                                <div class="list-group-item d-flex justify-content-between align-items-center py-2 border-0 border-bottom bg-light">
                                    @if (inlineEditId == comp.Id)
                                    {
                                        <div class="d-flex w-100 align-items-center">
                                            <input type="text" class="form-control form-control-sm me-2 fw-bold" @bind="inlineEditTitle" />
                                            <button class="btn btn-sm btn-success me-1 shadow-sm" @onclick="() => SaveInlineEdit(comp)"><i class="bi bi-check-lg"></i></button>
                                            <button class="btn btn-sm btn-light border" @onclick="CancelInlineEdit"><i class="bi bi-x-lg"></i></button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center pe-3 flex-grow-1">
                                            <i class="bi @(string.IsNullOrEmpty(comp.PdfFilePath) ? "bi-card-text text-secondary" : "bi-link-45deg text-success") fs-5 me-2 flex-shrink-0"></i>
                                            <span class="fw-bold text-dark text-wrap">@comp.Title</span>
                                        </div>
                                        <div class="d-flex align-items-center gap-1 me-2 border-end pe-2">
                                            <input type="number" class="form-control form-control-sm text-center" style="width: 50px; font-size: 0.8rem;" min="1" max="10" title="Peso"
                                                   @bind="comp.Weight" @bind:after="() => SaveComponentWeight(comp)" />
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size: 0.7rem; width: 42px;">@GetComponentPercentage(comp)%</span>
                                        </div>
                                        <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                            <button class="btn btn-link p-0 text-primary text-decoration-none shadow-none" title="Editar" @onclick="() => StartInlineEdit(comp)">
                                                <i class="bi bi-pencil-square fs-6 lh-1"></i>
                                            </button>
                                            <button class="btn btn-link p-0 text-danger text-decoration-none shadow-none" title="Remover" @onclick="() => DeleteComponent(comp.Id)">
                                                <i class="bi bi-trash3 fs-6 lh-1"></i>
                                            </button>
                                        </div>
                                    }
                                </div>

                                @foreach (var child in children)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center py-2 border-0 border-bottom ms-4">
                                        @if (inlineEditId == child.Id)
                                        {
                                            <div class="d-flex w-100 align-items-center">
                                                <input type="text" class="form-control form-control-sm me-2" @bind="inlineEditTitle" />
                                                <button class="btn btn-sm btn-success me-1 shadow-sm" @onclick="() => SaveInlineEdit(child)"><i class="bi bi-check-lg"></i></button>
                                                <button class="btn btn-sm btn-light border" @onclick="CancelInlineEdit"><i class="bi bi-x-lg"></i></button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center pe-3 flex-grow-1">
                                                <i class="bi @(string.IsNullOrEmpty(child.PdfFilePath) ? "bi-card-text text-secondary" : "bi-link-45deg text-success") fs-6 me-2 flex-shrink-0"></i>
                                                <span class="fw-semibold text-dark text-wrap" style="font-size: 0.95rem;">@child.Title</span>
                                            </div>
                                            <div class="d-flex align-items-center gap-1 me-2 border-end pe-2">
                                                <input type="number" class="form-control form-control-sm text-center" style="width: 50px; font-size: 0.8rem;" min="1" max="10" title="Peso"
                                                       @bind="child.Weight" @bind:after="() => SaveComponentWeight(child)" />
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size: 0.7rem; width: 42px;">@GetComponentPercentage(child)%</span>
                                            </div>
                                            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                                <button class="btn btn-link p-0 text-primary text-decoration-none shadow-none" title="Editar" @onclick="() => StartInlineEdit(child)">
                                                    <i class="bi bi-pencil-square fs-6 lh-1"></i>
                                                </button>
                                                <button class="btn btn-link p-0 text-danger text-decoration-none shadow-none" title="Remover" @onclick="() => DeleteComponent(child.Id)">
                                                    <i class="bi bi-trash3 fs-6 lh-1"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                }

                                @if (inlineEditId == comp.Id && comp.ParentComponentId == null)
                                {
                                    @foreach (var newChild in inlineNewChildren)
                                    {
                                        <div class="list-group-item d-flex align-items-center py-2 border-0 border-bottom ms-4" style="background-color: #f8f9fa;">
                                            <i class="bi bi-arrow-return-right text-muted me-2"></i>
                                            <input type="text"
                                                   class="form-control form-control-sm @(string.IsNullOrWhiteSpace(newChild.Text) ? "draft-empty" : "draft-filled-success")"
                                                   placeholder="Adicionar novo sub-parâmetro..."
                                                   @bind="newChild.Text"
                                                   @bind:event="oninput"
                                                   @onkeyup="CheckInlineChildrenState" />
                                        </div>
                                    }
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light text-center border mb-4" style="border-radius: 8px;">
                            <span class="text-muted small">Nenhum item adicionado a esta fase.</span>
                        </div>
                    }

                    <div class="p-4 rounded bg-white shadow-sm" style="border: 1px dashed #ced4da;">

                        @if (activeModalStage.Value.Stage == ModuleStage.Teorica)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-bold text-primary mb-0">@(componentToEdit.Id == 0 ? "Adicionar Nova Componente Teórica" : "A Editar Item...")</h6>
                                @if (componentToEdit.Id != 0)
                                {
                                    <button class="btn btn-sm btn-light border" @onclick="ResetForm">Cancelar Edição</button>
                                }
                            </div>

                            <div class="mb-3">
                                <input class="form-control shadow-sm border-0 bg-light fw-bold" placeholder="Título (Ex: Manual de Ventilação)..." @bind="componentToEdit.Title" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-semibold text-muted mb-1">Instruções / Descrição (Opcional)</label>
                                <textarea class="form-control shadow-sm border-0 bg-light" rows="3" placeholder="Ex: Leiam o capítulo 3..." @bind="componentToEdit.Description"></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-semibold text-muted mb-1">URL ou Anexo (Opcional)</label>
                                <div class="input-group shadow-sm" style="border-radius: 8px; overflow: hidden;">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-link-45deg"></i></span>
                                    <input class="form-control border-0 bg-light" placeholder="Ex: https://youtube.com/..." @bind="componentToEdit.PdfFilePath" disabled="@isUploading" />
                                    <label class="btn btn-secondary border-0 m-0 d-flex align-items-center px-3" style="cursor: pointer; background-color: #6A96A6;">
                                        <i class="bi bi-cloud-arrow-up me-2"></i> Explorar...
                                        <InputFile OnChange="HandleFileUpload" class="d-none" accept=".pdf,.doc,.docx" />
                                    </label>
                                </div>
                                @if (isUploading)
                                {
                                    <div class="form-text text-primary small mt-2 fw-semibold">
                                        <div class="spinner-border spinner-border-sm me-2" role="status"></div> A enviar ficheiro...
                                    </div>
                                }
                            </div>

                            <div class="text-end mt-4">
                                <button class="btn text-white px-4 shadow-sm" style="background-color: #6A96A6;" @onclick="SaveComponent" disabled="@isSavingModal">
                                    <i class="bi bi-save me-2"></i> @(isSavingModal ? "A Guardar..." : "Guardar")
                                </button>
                            </div>
                        }
                        else
                        {
                            <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-list-task me-2"></i>Adicionar Parâmetros</h6>

                            <div class="d-flex flex-column gap-2 mb-3">
                                @foreach (var parent in drafts)
                                {
                                    <div @onfocusin="() => activeDraftParent = parent">
                                        <input type="text"
                                               class="form-control mb-1 @(string.IsNullOrWhiteSpace(parent.Text) ? "text-muted" : "border-success fw-bold")"
                                               placeholder="Grupo ou Tarefa principal..."
                                               style="@(string.IsNullOrWhiteSpace(parent.Text) ? "border: 2px dashed #adb5bd !important; background-color: #f8f9fa;" : "border: 2px solid #198754;")"
                                               @bind="parent.Text"
                                               @bind:event="oninput"
                                               @onkeyup="() => CheckListState(parent)" />

                                        @if (!string.IsNullOrWhiteSpace(parent.Text) || parent.Children.Any(f => !string.IsNullOrWhiteSpace(f.Text)))
                                        {
                                            <div class="ms-4 mb-2 d-flex flex-column gap-1">
                                                @foreach (var child in parent.Children)
                                                {
                                                    @if (!string.IsNullOrWhiteSpace(child.Text) || activeDraftParent == parent)
                                                    {
                                                        <div class="d-flex align-items-center">
                                                            <i class="bi bi-arrow-return-right text-muted me-2"></i>
                                                            <input type="text"
                                                                   class="form-control form-control-sm @(string.IsNullOrWhiteSpace(child.Text) ? "text-muted" : "border-dark")"
                                                                   placeholder="Sub-parâmetro..."
                                                                   style="@(string.IsNullOrWhiteSpace(child.Text) ? "border: 2px dashed #adb5bd !important; background-color: #f8f9fa;" : "border: 2px solid #343a40;")"
                                                                   @bind="child.Text"
                                                                   @bind:event="oninput"
                                                                   @onkeyup="() => CheckListState(parent)" />
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            @if (drafts.Any(p => !string.IsNullOrWhiteSpace(p.Text)))
                            {
                                <div class="text-end mt-2">
                                    <button class="btn btn-success px-4 fw-bold shadow-sm" @onclick="SaveRapidStructure" disabled="@isSavingModal">
                                        @if (isSavingModal)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }
                                        Guardar Estrutura
                                    </button>
                                </div>
                            }
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private PathwayCreateDTO pathwayDto = new PathwayCreateDTO { MinimumPassScore = 50, MinimumApprovalScore = 75 };
    private Pathway? activePathway;
    private string newModuleTitle = string.Empty;
    private List<Module> savedModules = new();
    private List<PathwayTagDto> existingPathways = new();
    private int selectedExistingPathwayId = 0;
    private int expandedModuleId = 0;
    private bool isCopying = false;

    [Parameter] public int? PathwayIdToLoad { get; set; }
    [SupplyParameterFromQuery(Name = "from")] public string? FromSource { get; set; }

    private bool isUploading = false;

    private List<(ModuleStage Stage, string Title, string Icon, ModuleStage? CopyFromStage)> stagesToRender = new()
    {
        (ModuleStage.Teorica, "Componente Teórica", "bi-journal-text", null),
        (ModuleStage.ObservacaoPassiva, "Observação Passiva", "bi-eye", null),
        (ModuleStage.ObservacaoParticipada, "Observação Participada", "bi-people", ModuleStage.ObservacaoPassiva),
        (ModuleStage.PraticaAssistida, "Prática Assistida", "bi-person-gear", ModuleStage.ObservacaoParticipada),
        (ModuleStage.PraticaSupervisionada, "Prática Supervisionada", "bi-person-check", ModuleStage.PraticaAssistida)
    };

    private Module? activeModalModule;
    private (ModuleStage Stage, string Title, string Icon, ModuleStage? CopyFromStage)? activeModalStage;
    private ModuleComponent componentToEdit = new();
    private bool isSavingModal = false;

    private int? inlineEditId = null;
    private string inlineEditTitle = string.Empty;
    private List<DraftChild> inlineNewChildren = new() { new DraftChild() };
    private DraftParent? activeDraftParent = null;

    public class DraftParent
    {
        public string Text { get; set; } = "";
        public List<DraftChild> Children { get; set; } = new() { new DraftChild() };
    }
    public class DraftChild { public string Text { get; set; } = ""; }

    private List<DraftParent> drafts = new() { new DraftParent() };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            var currentUser = await LocalStorage.GetItemAsync<User>("user");
            existingPathways = await Http.GetFromJsonAsync<List<PathwayTagDto>>($"api/Pathway/supervisor/{currentUser.Id}") ?? new();

            if (PathwayIdToLoad.HasValue && PathwayIdToLoad.Value > 0)
            {
                selectedExistingPathwayId = PathwayIdToLoad.Value;
                await LoadExistingPathway();
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadExistingPathway()
    {
        if (selectedExistingPathwayId == 0) return;

        try
        {
            isLoading = true;
            var response = await Http.GetAsync($"api/Pathway/{selectedExistingPathwayId}");
            if (response.IsSuccessStatusCode)
            {
                activePathway = await response.Content.ReadFromJsonAsync<Pathway>();
                if (activePathway != null)
                {
                    savedModules = activePathway.Modules ?? new List<Module>();
                }
            }
        }
        finally
        {
            isLoading = false;
        }
    }

