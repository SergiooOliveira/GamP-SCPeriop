@page "/supervisor/pathway-builder"
@page "/supervisor/pathway-builder/{PathwayIdToLoad:int}"
@layout TopNavBarLayout
@inject HttpClient Http
@inject NavigationManager Nav
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@using GamP_SCPeriop.Components
@using GamP_SCPeriop.Shared.Entity.Model
@using GamP_SCPeriop.Shared.Enum
@using GamP_SCPeriop.Shared.Data

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Construtor de Percurso (Pathway)</h2>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center mt-5">
            <div class="spinner-border" style="color: #6A96A6;" role="status">
                <span class="visually-hidden">A carregar...</span>
            </div>
        </div>
    }
    else if (activePathway == null)
    {
        <!-- SELEÇÃO INICIAL (Carregar ou Criar Novo) -->
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card shadow-sm p-4 border-0 h-100" style="border-radius: 15px; background-color: #f8f9fa;">
                    <h5 class="mb-3 fw-bold text-secondary"><i class="bi bi-folder2-open me-2"></i>Carregar Existente</h5>
                    <p class="text-muted small mb-3">Selecione um percurso já criado para continuar a editá-lo.</p>

                    <div class="input-group">
                        <select class="form-select" @bind="selectedExistingPathwayId">
                            <option value="0" selected disabled>Selecione um percurso...</option>
                            @foreach (var p in existingPathways)
                            {
                                <option value="@p.PathwayId">@p.Title</option>
                            }
                        </select>
                        <button class="btn btn-secondary px-3" @onclick="LoadExistingPathway" disabled="@(selectedExistingPathwayId == 0)">
                            <i class="bi bi-cloud-download me-2"></i>Carregar
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm p-4 border-0 h-100" style="border-radius: 15px; background-color: #f8f9fa;">
                    <h5 class="mb-3 fw-bold text-primary"><i class="bi bi-plus-circle me-2"></i>Criar Novo Percurso</h5>

                    <div class="mb-3">
                        <input @bind="pathwayDto.Title" class="form-control" placeholder="Título (Ex: Enfermagem Cirúrgica)" />
                    </div>

                    <div class="row mb-3 g-2">
                        <div class="col-6">
                            <label class="form-label small text-muted mb-1">Mín. Passar (%)</label>
                            <input type="number" @bind="pathwayDto.MinimumPassScore" class="form-control form-control-sm" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted mb-1">Mín. Aprovação (%)</label>
                            <input type="number" @bind="pathwayDto.MinimumApprovalScore" class="form-control form-control-sm" />
                        </div>
                    </div>

                    <button @onclick="CreatePathway" class="btn text-white fw-bold w-100" style="border-radius: 10px; background-color: #6A96A6; border: none;">
                        Criar e Iniciar
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- CONSTRUTOR ATIVO (Ligação ao Componente Partilhado) -->
        <div class="alert alert-success d-flex justify-content-between align-items-center shadow-sm" style="border-radius: 10px; border-left: 5px solid #198754;">
            <div>
                <span class="text-muted small">Percurso Ativo:</span><br />
                <strong class="fs-5">@activePathway.Title</strong>
            </div>
            <div>
                <span class="badge bg-success fs-6 me-2">ID: @activePathway.Id</span>
                <button class="btn btn-sm btn-outline-success" @onclick="CloseActivePathway"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>

        <div class="mt-4 card shadow-sm p-4 border-0" style="border-radius: 15px;">
            <PathwayBuilderComponent 
                IsTemplateMode="false"
                ParentTitle="@activePathway.Title"
                Modules="@BuilderModules"
                OnCreateModule="CreateModuleFromBuilder"
                OnDeleteModule="DeleteActiveModule"
                OnUpdateModuleWeight="SaveModuleWeightFromBuilder"
                OnUpdateTimeline="HandleTimelineUpdateFromBuilder"
                OnSaveRapidStructureEvent="SaveRapidStructureFromBuilder"
                OnSaveTheoreticalEvent="SaveTheoreticalFromBuilder"
                OnCopyComponentsEvent="CopyComponentsFromBuilder"
                OnDeleteComponent="DeleteComponentFromBuilder"
                OnSaveBulkEditEvent="SaveBulkEditFromBuilder" />
        </div>
    }
</div>

@code {
    #region [ Variáveis Iniciais e Injectáveis ]

    [Parameter] public int? PathwayIdToLoad { get; set; }
    [SupplyParameterFromQuery(Name = "from")] public string? FromSource { get; set; }

    private bool isLoading = true;
    private PathwayCreateDTO pathwayDto = new PathwayCreateDTO { MinimumPassScore = 50, MinimumApprovalScore = 75 };
    private Pathway? activePathway;
    private List<Module> savedModules = new();
    private List<PathwayTagDto> existingPathways = new();
    private int selectedExistingPathwayId = 0;

    /// <summary>
    /// Traduz os modelos base de dados para o DTO que o Componente visual espera
    /// </summary>
    private List<BuilderModuleDto> BuilderModules => savedModules.Select(m => new BuilderModuleDto
    {
        Id = m.Id,
        Title = m.Title,
        Weight = m.Weight,
        StageTimelines = m.StageTimelines,
        Components = m.Components?.Select(c => new BuilderComponentDto
        {
            Id = c.Id,
            Title = c.Title,
            Description = c.Description,
            Stage = c.Stage,
            Weight = c.Weight,
            ParentComponentId = c.ParentComponentId,
            PdfFilePath = c.PdfFilePath
        }).ToList() ?? new List<BuilderComponentDto>()
    }).ToList();

    #endregion

    #region [ Inicialização e Gestão Global de Percursos ]

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            var currentUser = await LocalStorage.GetItemAsync<User>("user");
            existingPathways = await Http.GetFromJsonAsync<List<PathwayTagDto>>($"api/Pathway/supervisor/{currentUser.Id}") ?? new();

            if (PathwayIdToLoad.HasValue && PathwayIdToLoad.Value > 0)
            {
                selectedExistingPathwayId = PathwayIdToLoad.Value;
                await LoadExistingPathway();
            }
        }
        finally { isLoading = false; }
    }

    private async Task LoadExistingPathway()
    {
        if (selectedExistingPathwayId == 0) return;

        try
        {
            isLoading = true;
            var response = await Http.GetAsync($"api/Pathway/{selectedExistingPathwayId}");
            if (response.IsSuccessStatusCode)
            {
                activePathway = await response.Content.ReadFromJsonAsync<Pathway>();
                if (activePathway != null) savedModules = activePathway.Modules ?? new List<Module>();
            }
        }
        finally { isLoading = false; }
    }

    private void CloseActivePathway()
    {
        if (FromSource == "dashboard") Nav.NavigateTo("/dashboard");
        else
        {
            activePathway = null;
            savedModules.Clear();
            selectedExistingPathwayId = 0;
            Nav.NavigateTo("/supervisor/pathway-builder");
        }
    }

    private async Task CreatePathway()
    {
        if (string.IsNullOrWhiteSpace(pathwayDto.Title)) return;
        var response = await Http.PostAsJsonAsync("api/Pathway", pathwayDto);
        if (response.IsSuccessStatusCode)
        {
            activePathway = await response.Content.ReadFromJsonAsync<Pathway>();
            existingPathways = await Http.GetFromJsonAsync<List<PathwayTagDto>>("api/Pathway/available-options") ?? new();
        }
    }

    #endregion

    #region [ Módulos, Pesos e Timeline (Comunicação com a API) ]

    private async Task CreateModuleFromBuilder(string title)
    {
        if (string.IsNullOrWhiteSpace(title) || activePathway == null) return;

        var dto = new ModuleCreateDTO { Title = title, PathwayId = activePathway.Id };
        var response = await Http.PostAsJsonAsync("api/Module", dto);

        if (response.IsSuccessStatusCode)
        {
            var savedMod = await response.Content.ReadFromJsonAsync<Module>();
            if (savedMod != null)
            {
                savedMod.Components = new List<ModuleComponent>();
                savedMod.StageTimelines = new List<ModuleStageTimeline>();

                foreach (var stage in GetTimelineStages()) GetOrCreateTimeline(savedMod, stage);
                await Http.PutAsJsonAsync($"api/Module/{savedMod.Id}", savedMod);

                savedModules.Add(savedMod);
                StateHasChanged();
            }
        }
    }

    private async Task DeleteActiveModule(int moduleId)
    {
        var response = await Http.DeleteAsync($"api/Module/{moduleId}");
        if (response.IsSuccessStatusCode)
        {
            var mod = savedModules.FirstOrDefault(m => m.Id == moduleId);
            if (mod != null) savedModules.Remove(mod);
            StateHasChanged();
        }
    }

    private async Task SaveModuleWeightFromBuilder(BuilderModuleDto mod)
    {
        var dbMod = savedModules.FirstOrDefault(m => m.Id == mod.Id);
        if (dbMod != null)
        {
            dbMod.Weight = mod.Weight;
            await Http.PutAsJsonAsync($"api/Module/{mod.Id}", dbMod);
            StateHasChanged();
        }
    }

    private async Task HandleTimelineUpdateFromBuilder((int ModuleId, ModuleStage Stage, DateTime Date, bool IsStart) data)
    {
        var mod = savedModules.FirstOrDefault(m => m.Id == data.ModuleId);
        if (mod == null) return;

        var timeline = GetOrCreateTimeline(mod, data.Stage);

        if (data.IsStart)
        {
            var oldDuration = timeline.EndDate - timeline.StartDate;
            if (oldDuration.TotalDays < 0) oldDuration = TimeSpan.FromDays(7);
            timeline.StartDate = data.Date;
            timeline.EndDate = data.Date.Add(oldDuration);
            RecalculateStageDatesLocal(mod, data.Stage);
        }
        else
        {
            if (data.Date < timeline.StartDate) data.Date = timeline.StartDate.AddDays(1);
            timeline.EndDate = data.Date;
            RecalculateStageDatesLocal(mod, data.Stage);
        }

        await Http.PutAsJsonAsync($"api/Module/{mod.Id}", mod);
        StateHasChanged();
    }

    #endregion

    #region [ Auxiliares de Timeline ]

    private List<ModuleStage> GetTimelineStages()
    {
        return new List<ModuleStage> { 
            ModuleStage.ObservacaoPassiva, 
            ModuleStage.ObservacaoParticipada, 
            ModuleStage.PraticaAssistida, 
            ModuleStage.PraticaSupervisionada 
        };
    }

    private ModuleStageTimeline GetOrCreateTimeline(Module mod, ModuleStage stage)
    {
        mod.StageTimelines ??= new List<ModuleStageTimeline>();
        var timeline = mod.StageTimelines.FirstOrDefault(t => t.Stage == stage);

        if (timeline == null)
        {
            var defaultStart = DateTime.Today;
            var timelineStages = GetTimelineStages();
            var currentIndex = timelineStages.IndexOf(stage);

            if (currentIndex > 0)
            {
                var prevStage = timelineStages[currentIndex - 1];
                var prevTimeline = mod.StageTimelines.FirstOrDefault(t => t.Stage == prevStage);
                if (prevTimeline != null) defaultStart = prevTimeline.EndDate.AddDays(1);
            }

            timeline = new ModuleStageTimeline
            {
                ModuleId = mod.Id, Stage = stage, StartDate = defaultStart, EndDate = defaultStart.AddDays(7)
            };
            mod.StageTimelines.Add(timeline);
        }
        return timeline;
    }

    private void RecalculateStageDatesLocal(Module mod, ModuleStage changedStage)
    {
        var timelineStages = GetTimelineStages();
        var startIndex = timelineStages.IndexOf(changedStage);

        if (startIndex != -1)
        {
            for (int i = startIndex + 1; i < timelineStages.Count; i++)
            {
                var previousTimeline = GetOrCreateTimeline(mod, timelineStages[i - 1]);
                var currentTimeline = GetOrCreateTimeline(mod, timelineStages[i]);
                var currentDuration = currentTimeline.EndDate - currentTimeline.StartDate;
                if (currentDuration.TotalDays < 0) currentDuration = TimeSpan.FromDays(7);

                currentTimeline.StartDate = previousTimeline.EndDate.AddDays(1);
                currentTimeline.EndDate = currentTimeline.StartDate.Add(currentDuration);
            }
        }
    }

    #endregion

    #region [ Gravações do Modal (Componentes e Tarefas) ]

    private async Task SaveRapidStructureFromBuilder((int ModuleId, ModuleStage Stage, List<PathwayBuilderComponent.DraftParent> Drafts) data)
    {
        foreach (var parent in data.Drafts.Where(p => !string.IsNullOrWhiteSpace(p.Text)))
        {
            var dtoParent = new ModuleComponentCreateDTO { ModuleId = data.ModuleId, Title = parent.Text, Stage = data.Stage };
            var responseParent = await Http.PostAsJsonAsync("api/ModuleComponent", dtoParent);
            if (responseParent.IsSuccessStatusCode)
            {
                var savedParent = await responseParent.Content.ReadFromJsonAsync<ModuleComponent>();
                if (savedParent != null)
                {
                    foreach (var child in parent.Children.Where(f => !string.IsNullOrWhiteSpace(f.Text)))
                    {
                        var dtoChild = new ModuleComponentCreateDTO { ModuleId = data.ModuleId, Title = child.Text, Stage = data.Stage, ParentComponentId = savedParent.Id };
                        await Http.PostAsJsonAsync("api/ModuleComponent", dtoChild);
                    }
                }
            }
        }
        await LoadExistingPathway();
        StateHasChanged();
    }

    private async Task SaveTheoreticalFromBuilder((int ModuleId, BuilderComponentDto Component) data)
    {
        if (data.Component.Id == 0)
        {
            var dto = new ModuleComponentCreateDTO { ModuleId = data.ModuleId, Title = data.Component.Title, Description = data.Component.Description, Stage = data.Component.Stage };
            await Http.PostAsJsonAsync("api/ModuleComponent", dto);
        }
        else await Http.PutAsJsonAsync($"api/ModuleComponent/{data.Component.Id}", data.Component);
        
        await LoadExistingPathway();
        StateHasChanged();
    }

    private async Task SaveBulkEditFromBuilder((int ModuleId, ModuleStage Stage, List<BuilderComponentDto> UpdatedComponents, Dictionary<int, List<(string Title, int Weight)>> NewSubTasks) data)
    {
        foreach (var comp in data.UpdatedComponents)
        {
            var dbComp = await Http.GetFromJsonAsync<ModuleComponent>($"api/ModuleComponent/{comp.Id}");
            if (dbComp != null)
            {
                dbComp.Title = comp.Title;
                dbComp.Weight = comp.Weight;
                await Http.PutAsJsonAsync($"api/ModuleComponent/{comp.Id}", dbComp);
            }
        }

        foreach (var kvp in data.NewSubTasks)
        {
            foreach (var task in kvp.Value)
            {
                var dtoChild = new ModuleComponentCreateDTO
                {
                    ModuleId = data.ModuleId,
                    Title = task.Title,
                    Stage = data.Stage,
                    ParentComponentId = kvp.Key,
                    Weight = task.Weight
                };
                await Http.PostAsJsonAsync("api/ModuleComponent", dtoChild);
            }
        }

        await LoadExistingPathway();
        StateHasChanged();
    }

    private async Task CopyComponentsFromBuilder((int ModuleId, ModuleStage CurrentStage, ModuleStage SourceStage) data)
    {
        await Http.PostAsync($"api/ModuleComponent/copy?moduleId={data.ModuleId}&fromStage={data.SourceStage}&toStage={data.CurrentStage}", null);
        await LoadExistingPathway();
        StateHasChanged();
    }

    private async Task DeleteComponentFromBuilder(int componentId)
    {
        await Http.DeleteAsync($"api/ModuleComponent/{componentId}");
        await LoadExistingPathway();
        StateHasChanged();
    }

    #endregion
}