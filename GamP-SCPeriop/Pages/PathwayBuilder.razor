    private async Task CreateModule()
    {
        if (string.IsNullOrWhiteSpace(newModuleTitle) || activePathway == null) return;

        var dto = new ModuleCreateDTO { Title = newModuleTitle, PathwayId = activePathway.Id };
        var response = await Http.PostAsJsonAsync("api/Module", dto);

        if (response.IsSuccessStatusCode)
        {
            var savedMod = await response.Content.ReadFromJsonAsync<Module>();
            if (savedMod != null)
            {
                savedMod.Components = new List<ModuleComponent>();
                savedMod.StageTimelines = new List<ModuleStageTimeline>();

                // 1. Aproveitar o TEU método existente para gerar as datas padrão!
                foreach (var stage in GetTimelineStages())
                {
                    GetOrCreateTimeline(savedMod, stage);
                }

                // 2. Gravar imediatamente as datas geradas na Base de Dados
                await Http.PutAsJsonAsync($"api/Module/{savedMod.Id}", savedMod);

                savedModules.Add(savedMod);
                newModuleTitle = string.Empty;
            }
        }
    }

