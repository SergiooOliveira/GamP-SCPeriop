@page "/students"
@layout TopNavBarLayout
@inject HttpClient Http

<div class="max-width-container container-fluid py-4">
    <!-- Header & Search Bar -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h3 class="fw-bold mb-0">Gestão de Alunos</h3>
            <span class="text-muted small">Gerir inscrições e percursos de aprendizagem</span>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <div class="input-group shadow-sm" style="border-radius: 20px; overflow: hidden; max-width: 350px; float: right;">
                <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-0 bg-white" placeholder="Pesquisar aluno..." @bind="searchQuery" @bind:event="oninput">
            </div>
        </div>
    </div>

    <!-- Student List Card -->
    <div class="card shadow-sm border-0" style="border-radius: 20px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 fw-bold border-0 py-3">Aluno</th>
                        <th class="fw-bold border-0 py-3">Email</th>
                        <th class="fw-bold border-0 py-3">Percursos Ativos</th>
                        <th class="fw-bold border-0 py-3">Progresso Global</th>
                        <th class="fw-bold border-0 py-3 text-end pe-4">Último Acesso</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Example Row (We will loop this later) -->
                    <tr @onclick="() => OpenStudentProfile(1)" style="cursor: pointer;">
                        <td class="ps-4 py-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-primary text-white d-flex justify-content-center align-items-center flex-shrink-0" style="width: 40px; height: 40px;">
                                    <i class="bi bi-person-fill fs-5"></i>
                                </div>
                                <div class="fw-bold text-dark">João Silva</div>
                            </div>
                        </td>
                        <td class="text-muted small">joao.silva@uminho.pt</td>
                        <td>
                            <!-- Pathway Tags -->
                            <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary fw-normal px-2 py-1 me-1">Anestesia</span>
                            <span class="badge rounded-pill bg-success bg-opacity-10 text-success fw-normal px-2 py-1">Bloco Operatório</span>
                        </td>
                        <td style="width: 200px;">
                            <div class="d-flex align-items-center gap-2">
                                <div class="bg-light flex-grow-1" style="height: 6px; border-radius: 10px; overflow: hidden;">
                                    <div class="bg-primary h-100" style="width: 45%;"></div>
                                </div>
                                <small class="text-muted">45%</small>
                            </div>
                        </td>
                        <td class="text-end pe-4 text-muted small">Há 2 horas</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- STUDENT PROFILE MODAL -->
@if (showModal)
{
    <div class="modal-backdrop fade show" style="background-color: rgba(0,0,0,0.5);"></div>
    <div class="modal fade show d-block" tabindex="-1" @onclick="CloseModal">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content border-0 shadow" style="border-radius: 20px;">
                
                <!-- Modal Header (Profile Info) -->
                <div class="modal-header border-0 pb-0 d-flex flex-column align-items-center mt-4">
                    <button type="button" class="btn-close position-absolute top-0 end-0 m-3" @onclick="CloseModal"></button>
                    
                    <div class="rounded-circle bg-secondary text-white d-flex justify-content-center align-items-center mb-3 shadow-sm" style="width: 80px; height: 80px;">
                        <i class="bi bi-person-fill" style="font-size: 2.5rem;"></i>
                    </div>
                    <h4 class="fw-bold mb-0">João Silva</h4>
                    <p class="text-muted small mb-2">joao.silva@uminho.pt</p>
                </div>

                <!-- Modal Body (Action Area) -->
                <div class="modal-body px-4 pb-4">
                    <hr class="text-muted opacity-25">
                    
                    <h6 class="fw-bold mb-3">Atribuir Novo Percurso</h6>
                    
                    <div class="d-flex gap-2">
                        <select class="form-select border-0 bg-light shadow-sm" style="border-radius: 10px;">
                            <option selected disabled>Selecione um percurso...</option>
                            <option value="1">Urgências</option>
                            <option value="2">Cuidados Intensivos</option>
                        </select>
                        <button class="btn btn-primary px-4 shadow-sm" style="border-radius: 10px;">Adicionar</button>
                    </div>

                    <div class="mt-4">
                        <h6 class="fw-bold mb-2">Percursos Atuais</h6>
                        <ul class="list-group list-group-flush small">
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center border-0">
                                <span><i class="bi bi-journal-text me-2 text-primary"></i> Anestesia</span>
                                <span class="badge bg-light text-dark">Em Curso</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool showModal = false;
    private string searchQuery = "";

    private void OpenStudentProfile(int studentId)
    {
        // Later: Fetch student details by ID here
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }
}