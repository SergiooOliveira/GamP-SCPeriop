@using GamP_SCPeriop.Shared.Entity.Model
@using GamP_SCPeriop.Shared.Data
@using GamP_SCPeriop.Shared.Enum

<div class="mt-4 card shadow-sm p-4 border-0" style="border-radius: 15px;">
    <h5 class="mb-3 fw-bold text-primary">Gestão de Módulos</h5>

    @if (Modules.Any())
    {
        <div class="mb-4">
            @foreach (var mod in Modules)
            {
                var isExpanded = expandedModuleId == mod.Id;

                <div class="card border-0 shadow-sm mb-3" style="border-radius: 10px; overflow: hidden;">
                    <!-- CABEÇALHO DO MÓDULO -->
                    <div class="card-header bg-white border-0 p-0 d-flex align-items-center pe-4">
                        <button class="btn btn-link text-decoration-none fw-bold text-dark text-start flex-grow-1 p-3 px-4 shadow-none"
                                type="button" @onclick="() => ToggleModule(mod.Id)">
                            <i class="bi bi-folder2-open text-primary me-3 fs-5"></i> @mod.Title
                        </button>

                        <!-- PESO (Escondido se for Template) -->
                        @if (!IsTemplateMode)
                        {
                            <div class="d-flex align-items-center gap-2 border-end pe-3 me-3" @onclick:stopPropagation="true">
                                <small class="text-muted fw-bold">Peso:</small>
                                <input type="number" class="form-control form-control-sm text-center" style="width: 60px;" min="1" max="10"
                                       @bind="mod.Weight" @bind:after="() => HandleWeightChange(mod)" />
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25" style="width: 48px;">
                                    @GetModulePercentage(mod)%
                                </span>
                            </div>
                        }

                        <div class="d-flex align-items-center gap-3">
                            <button class="btn btn-sm text-danger border-0 p-1 shadow-none" title="Eliminar Módulo"
                                    @onclick="() => OnDeleteModule.InvokeAsync(mod.Id)" @onclick:stopPropagation="true">
                                <i class="bi bi-trash3 fs-5"></i>
                            </button>
                            <i class="bi @(isExpanded ? "bi-chevron-up" : "bi-chevron-down") text-muted" style="cursor: pointer;" @onclick="() => ToggleModule(mod.Id)"></i>
                        </div>
                    </div>

                    <!-- CORPO DO MÓDULO (Fases) -->
                    @if (isExpanded)
                    {
                        <div class="card-body p-0 border-top">
                            <div class="list-group list-group-flush">
                                @foreach (var stageInfo in stagesToRender)
                                {
                                    var count = mod.Components.Count(c => c.Stage == stageInfo.Stage);

                                    <div class="list-group-item d-flex flex-column border-0 border-bottom p-0" style="background-color: #f8f9fa;">
                                        <div class="d-flex justify-content-between align-items-center px-4 py-3">
                                            
                                            <!-- Botão que vai abrir o Modal -->
                                            <button type="button" class="btn btn-link text-decoration-none p-0 d-flex align-items-center flex-grow-1 text-start shadow-none"
                                                    @onclick="() => OpenStageModal(mod, stageInfo)">
                                                <i class="bi @stageInfo.Icon me-3 text-secondary fs-5"></i>
                                                <span class="fw-semibold text-dark">@stageInfo.Title</span>
                                            </button>

                                            <div class="d-flex align-items-center gap-3">
                                                <!-- DATAS / TIMELINE (Escondido se for Template ou Teórica) -->
                                                @if (!IsTemplateMode && stageInfo.Stage != ModuleStage.Teorica)
                                                {
                                                    var timeline = GetTimeline(mod, stageInfo.Stage);
                                                    <div class="d-flex align-items-center gap-2 me-3" @onclick:stopPropagation="true">
                                                        <small class="text-muted fw-bold" style="font-size: 0.7rem;">Início:</small>
                                                        <input type="date" class="form-control form-control-sm text-center" style="width: 120px; font-size: 0.8rem;"
                                                               value="@timeline?.StartDate.ToString("yyyy-MM-dd")"
                                                               @onchange="(e) => HandleDateChange(mod.Id, stageInfo.Stage, e.Value?.ToString(), true)" />

                                                        <small class="text-muted fw-bold ms-1" style="font-size: 0.7rem;">Fim:</small>
                                                        <input type="date" class="form-control form-control-sm text-center" style="width: 120px; font-size: 0.8rem;"
                                                               value="@timeline?.EndDate.ToString("yyyy-MM-dd")"
                                                               @onchange="(e) => HandleDateChange(mod.Id, stageInfo.Stage, e.Value?.ToString(), false)" />
                                                    </div>
                                                }

                                                @if (count > 0)
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1 border border-success border-opacity-25">@count itens</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-muted border rounded-pill px-3 py-1">Vazio</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- ADICIONAR MÓDULO -->
    <div class="input-group shadow-sm" style="border-radius: 8px; overflow: hidden;">
        <input @bind="newModuleTitle" class="form-control border-0 p-3 bg-light" placeholder="Ex: Módulo 1 - Fundamentos" />
        <button @onclick="CreateModule" class="btn text-white fw-bold px-4" style="background-color: #6A96A6; border: none;">
            Adicionar Módulo
        </button>
    </div>
</div>

<!-- ============================================== -->
<!-- JANELA MODAL (FASES E TAREFAS)                 -->
<!-- ============================================== -->
@if (activeModalModule != null && activeModalStage.HasValue)
{
    <div class="modal-backdrop fade show" style="background-color: rgba(0,0,0,0.6); position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 1040;"></div>
    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1055;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow" style="border-radius: 15px; background-color: #f4f7f6;">

                <!-- Cabeçalho Modal -->
                <div class="modal-header border-bottom-0 pb-2 pt-4 px-4 bg-white" style="border-radius: 15px 15px 0 0;">
                    <div>
                        <span class="badge bg-secondary bg-opacity-10 text-secondary border mb-2">@activeModalModule.Title</span>
                        <h4 class="modal-title fw-bold text-primary"><i class="bi @activeModalStage.Value.Icon me-2"></i>@activeModalStage.Value.Title</h4>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseStageModal"></button>
                </div>

                <div class="modal-body px-4 py-4">
                    <!-- Controlos de Topo Modal -->
                    <div class="d-flex justify-content-between align-items-end mb-3">
                        <h6 class="fw-bold text-secondary text-uppercase small mb-0">Componentes Atuais</h6>

                        @if (activeModalStage.Value.CopyFromStage.HasValue)
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="CopyComponents" disabled="@isCopying">
                                @if (isCopying) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                else { <i class="bi bi-copy me-1"></i> }
                                Copiar da Fase Anterior
                            </button>
                        }

                       <button class="btn btn-sm @(isEditMode ? "btn-success" : "btn-outline-primary") ms-2" 
                                @onclick="async () => { if (isEditMode) await SaveChangesBulk(); else ToggleEditMode(); }" >
                            <i class="bi @(isEditMode ? "bi-check2-circle" : "bi-pencil-square") me-1"></i>
                            @(isEditMode ? "Concluir Edição" : "Editar Fase")
                        </button>
                    </div>

                    <!-- Mensagem de Validação -->
                    @if (!string.IsNullOrEmpty(validationError))
                    {
                        <div class="alert alert-danger py-2 mb-3 shadow-sm d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>Atenção:</strong>&nbsp;@validationError
                        </div>
                    }

                    <!-- Lista de Tarefas -->
                    @if (activeModalModule.Components != null && activeModalModule.Components.Any(c => c.Stage == activeModalStage.Value.Stage))
                    {
                        <div class="list-group mb-4 shadow-sm" style="border-radius: 8px;">
                            @{
                                var stageComponents = activeModalModule.Components.Where(c => c.Stage == activeModalStage.Value.Stage).ToList();
                                var topLevel = stageComponents.Where(c => c.ParentComponentId == null).ToList();
                            }

                            @foreach (var comp in topLevel)
                            {
                                var children = stageComponents.Where(c => c.ParentComponentId == comp.Id).ToList();

                                @if (isEditMode)
                                {
                                    <div class="mb-2">
                                        <!-- MODO EDIÇÃO: Pai -->
                                        <div class="d-flex align-items-center mb-1">
                                            <input type="text" class="form-control border-success fw-bold" @bind="comp.Title" />
                                            @if (!IsTemplateMode)
                                            {
                                                <div class="input-group input-group-sm mx-2" style="width: 80px;">
                                                    <input type="text" inputmode="numeric" class="form-control text-center px-1" style="width: 30px;" @bind="comp.Weight" />
                                                    <span class="input-group-text px-1">%</span>
                                                </div>
                                            }
                                            <button class="btn btn-link text-danger p-0 ms-1" @onclick="() => OnDeleteComponent.InvokeAsync(comp.Id)"><i class="bi bi-x-lg fs-5"></i></button>
                                        </div>

                                        <!-- MODO EDIÇÃO: Filhos Existentes -->
                                        @foreach (var child in children)
                                        {
                                            <div class="d-flex align-items-center ms-4 mb-2">
                                                <i class="bi bi-arrow-return-right text-muted me-2"></i>
                                                <input type="text" class="form-control border-dark" @bind="child.Title" />
                                                @if (!IsTemplateMode)
                                                {
                                                    <div class="input-group input-group-sm mx-2" style="width: 80px;">
                                                        <input type="text" inputmode="numeric" class="form-control text-center px-1" style="width: 30px;" @bind="child.Weight" />
                                                        <span class="input-group-text px-1">%</span>
                                                    </div>
                                                }
                                                <button class="btn btn-link text-danger p-0 ms-1" @onclick="() => OnDeleteComponent.InvokeAsync(child.Id)"><i class="bi bi-x-lg fs-5"></i></button>
                                            </div>
                                        }

                                        <!-- MODO EDIÇÃO: Rascunho para Novos Filhos -->
                                        @if (editModeNewChildren.ContainsKey(comp.Id))
                                        {
                                            @foreach (var newChild in editModeNewChildren[comp.Id])
                                            {
                                                <div class="d-flex align-items-center ms-4 mb-1">
                                                    <i class="bi bi-arrow-return-right text-muted me-2"></i>
                                                    <input type="text" class="form-control @(string.IsNullOrWhiteSpace(newChild.Text) ? "draft-empty" : "draft-filled-success")"
                                                           placeholder="Adicionar novo sub-parâmetro..."
                                                           style="@(string.IsNullOrWhiteSpace(newChild.Text) ? "border: 2px dashed #adb5bd !important; background-color: #f8f9fa;" : "border: 2px solid #198754;")"
                                                           @bind="newChild.Text"
                                                           @bind:event="oninput"
                                                           @onkeyup="() => CheckEditModeChildrenState(comp.Id)" />
            
                                                    <!-- NOVA CAIXA DE PERCENTAGEM QUE SÓ APARECE SE TIVER TEXTO -->
                                                    @if (!IsTemplateMode && !string.IsNullOrWhiteSpace(newChild.Text))
                                                    {
                                                        <div class="input-group input-group-sm mx-2" style="width: 80px;">
                                                            <input type="text" inputmode="numeric" class="form-control text-center px-1" @bind="newChild.Weight" />
                                                            <span class="input-group-text px-1">%</span>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                                else
                                {
                                    <!-- MODO LEITURA: A grelha limpa -->
                                    <div class="list-group-item d-flex justify-content-between align-items-center py-2 border-0 border-bottom bg-light">
                                        <div class="d-flex align-items-center pe-3 flex-grow-1">
                                            <i class="bi @(string.IsNullOrEmpty(comp.PdfFilePath) ? "bi-card-text text-secondary" : "bi-link-45deg text-success") fs-5 me-2 flex-shrink-0"></i>
                                            <span class="fw-bold text-dark text-wrap">@comp.Title</span>
                                        </div>

                                        @if (!IsTemplateMode)
                                        {
                                            <div class="d-flex align-items-center gap-1 me-2 pe-2">
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size: 0.7rem;">@comp.Weight%</span>
                                            </div>
                                        }
                                    </div>

                                    @foreach (var child in children)
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center py-2 border-0 border-bottom ms-4">
                                            <div class="d-flex align-items-center pe-3 flex-grow-1">
                                                <i class="bi @(string.IsNullOrEmpty(child.PdfFilePath) ? "bi-card-text text-secondary" : "bi-link-45deg text-success") fs-6 me-2 flex-shrink-0"></i>
                                                <span class="fw-semibold text-dark text-wrap" style="font-size: 0.95rem;">@child.Title</span>
                                            </div>

                                            @if (!IsTemplateMode)
                                            {
                                                <div class="d-flex align-items-center gap-1 me-2 pe-2">
                                                    <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size: 0.7rem;">@child.Weight%</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light text-center border mb-4" style="border-radius: 8px;">
                            <span class="text-muted small">Nenhum item adicionado a esta fase.</span>
                        </div>
                    }

                    <!-- Adicionar Novos Componentes -->
                    <div class="p-4 rounded bg-white shadow-sm" style="border: 1px dashed #ced4da;">
                        @if (activeModalStage.Value.Stage == ModuleStage.Teorica)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-bold text-primary mb-0">Adicionar Nova Componente Teórica</h6>
                                <button class="btn btn-sm btn-light border" @onclick="ResetForm">Limpar</button>
                            </div>

                            <div class="mb-3">
                                <input class="form-control shadow-sm border-0 bg-light fw-bold" placeholder="Título (Ex: Manual de Ventilação)..." @bind="componentToEdit.Title" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-semibold text-muted mb-1">Instruções / Descrição (Opcional)</label>
                                <textarea class="form-control shadow-sm border-0 bg-light" rows="3" placeholder="Ex: Leiam o capítulo 3..." @bind="componentToEdit.Description"></textarea>
                            </div>

                            <div class="text-end mt-4">
                                <button class="btn text-white px-4 shadow-sm" style="background-color: #6A96A6;" @onclick="SaveComponent" disabled="@isSavingModal">
                                    <i class="bi bi-save me-2"></i> @(isSavingModal ? "A Guardar..." : "Guardar")
                                </button>
                            </div>
                        }
                        else
                        {
                            <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-list-task me-2"></i>Adicionar Parâmetros</h6>

                            <div class="d-flex flex-column gap-2 mb-3">
                                @foreach (var parent in drafts)
                                {
                                    <div @onfocusin="() => activeDraftParent = parent">
                                        <input type="text"
                                               class="form-control mb-1 @(string.IsNullOrWhiteSpace(parent.Text) ? "text-muted" : "border-success fw-bold")"
                                               placeholder="Grupo ou Tarefa principal..."
                                               style="@(string.IsNullOrWhiteSpace(parent.Text) ? "border: 2px dashed #adb5bd !important; background-color: #f8f9fa;" : "border: 2px solid #198754;")"
                                               @bind="parent.Text"
                                               @bind:event="oninput"
                                               @onkeyup="() => CheckListState(parent)" />

                                        @if (!string.IsNullOrWhiteSpace(parent.Text) || parent.Children.Any(f => !string.IsNullOrWhiteSpace(f.Text)))
                                        {
                                            <div class="ms-4 mb-2 d-flex flex-column gap-1">
                                                @foreach (var child in parent.Children)
                                                {
                                                    @if (!string.IsNullOrWhiteSpace(child.Text) || activeDraftParent == parent)
                                                    {
                                                        <div class="d-flex align-items-center">
                                                            <i class="bi bi-arrow-return-right text-muted me-2"></i>
                                                            <input type="text"
                                                                   class="form-control form-control-sm @(string.IsNullOrWhiteSpace(child.Text) ? "text-muted" : "border-dark")"
                                                                   placeholder="Sub-parâmetro..."
                                                                   style="@(string.IsNullOrWhiteSpace(child.Text) ? "border: 2px dashed #adb5bd !important; background-color: #f8f9fa;" : "border: 2px solid #343a40;")"
                                                                   @bind="child.Text"
                                                                   @bind:event="oninput"
                                                                   @onkeyup="() => CheckListState(parent)" />
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            @if (drafts.Any(p => !string.IsNullOrWhiteSpace(p.Text)))
                            {
                                <div class="text-end mt-2">
                                    <button class="btn btn-success px-4 fw-bold shadow-sm" @onclick="SaveRapidStructure" disabled="@isSavingModal">
                                        @if (isSavingModal) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                        Guardar Estrutura
                                    </button>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    #region [ Parâmetros e Eventos (Comunicação com o Pai) ]
    
    [Parameter] public bool IsTemplateMode { get; set; } = false;
    [Parameter] public string ParentTitle { get; set; } = string.Empty;
    [Parameter] public List<BuilderModuleDto> Modules { get; set; } = new();

    // Eventos de Módulos e Datas
    [Parameter] public EventCallback<string> OnCreateModule { get; set; }
    [Parameter] public EventCallback<int> OnDeleteModule { get; set; }
    [Parameter] public EventCallback<BuilderModuleDto> OnUpdateModuleWeight { get; set; }
    [Parameter] public EventCallback<(int ModuleId, ModuleStage Stage, DateTime Date, bool IsStart)> OnUpdateTimeline { get; set; }

    // Eventos de Tarefas / Modal
    [Parameter] public EventCallback<int> OnDeleteComponent { get; set; }
    [Parameter] public EventCallback<(int ModuleId, ModuleStage Stage, List<DraftParent> Drafts)> OnSaveRapidStructureEvent { get; set; }
    [Parameter] public EventCallback<(int ModuleId, BuilderComponentDto Component)> OnSaveTheoreticalEvent { get; set; }
    [Parameter] public EventCallback<(int ModuleId, ModuleStage CurrentStage, ModuleStage SourceStage)> OnCopyComponentsEvent { get; set; }
    [Parameter] public EventCallback<(int ModuleId, ModuleStage Stage, List<BuilderComponentDto> UpdatedComponents, Dictionary<int, List<(string Title, int Weight)>> NewSubTasks)> OnSaveBulkEditEvent { get; set; }  

    #endregion

    #region [ Variáveis de Estado UI ]

    private int expandedModuleId = 0;
    private string newModuleTitle = string.Empty;

    // Estado do Modal
    private BuilderModuleDto? activeModalModule;
    private BuilderComponentDto componentToEdit = new();
    private (ModuleStage Stage, string Title, string Icon, ModuleStage? CopyFromStage)? activeModalStage;
    private bool isSavingModal = false;
    private bool isCopying = false;
    
    // Estado do Bulk Edit (Edição em Massa)
    private bool isEditMode = false;
    private string? validationError;
    private Dictionary<int, List<DraftChild>> editModeNewChildren = new();

    // Estado do Rascunho (Adicionar Nova Estrutura)
    public class DraftParent { public string Text { get; set; } = ""; public List<DraftChild> Children { get; set; } = new() { new DraftChild() }; }
    public class DraftChild { public string Text { get; set; } = ""; public int Weight { get; set; } = 0; }
    private List<DraftParent> drafts = new() { new DraftParent() };
    private DraftParent? activeDraftParent = null;

    // Definição estática das fases
    private List<(ModuleStage Stage, string Title, string Icon, ModuleStage? CopyFromStage)> stagesToRender = new()
    {
        (ModuleStage.Teorica, "Componente Teórica", "bi-journal-text", null),
        (ModuleStage.ObservacaoPassiva, "Observação Passiva", "bi-eye", null),
        (ModuleStage.ObservacaoParticipada, "Observação Participada", "bi-people", ModuleStage.ObservacaoPassiva),
        (ModuleStage.PraticaAssistida, "Prática Assistida", "bi-person-gear", ModuleStage.ObservacaoParticipada),
        (ModuleStage.PraticaSupervisionada, "Prática Supervisionada", "bi-person-check", ModuleStage.PraticaAssistida)
    };

    #endregion

    #region [ Ciclo de Vida ]

    /// <summary>
    /// Mantém o Modal atualizado sempre que a Base de Dados sofre alterações e redesenha.
    /// </summary>
    protected override void OnParametersSet()
    {
        if (activeModalModule != null)
        {
            activeModalModule = Modules.FirstOrDefault(m => m.Id == activeModalModule.Id);
        }
    }

    #endregion

    #region [ Controlo de Módulos e Visuais Base ]

    private void ToggleModule(int moduleId) => expandedModuleId = (expandedModuleId == moduleId) ? 0 : moduleId;

    private async Task CreateModule()
    {
        if (string.IsNullOrWhiteSpace(newModuleTitle)) return;
        await OnCreateModule.InvokeAsync(newModuleTitle);
        newModuleTitle = string.Empty;
    }

    private async Task HandleWeightChange(BuilderModuleDto mod)
    {
        if (mod.Weight < 1) mod.Weight = 1;
        if (mod.Weight > 10) mod.Weight = 10;
        await OnUpdateModuleWeight.InvokeAsync(mod);
    }

    private async Task HandleDateChange(int moduleId, ModuleStage stage, string? dateStr, bool isStart)
    {
        if (DateTime.TryParse(dateStr, out DateTime newDate))
        {
            await OnUpdateTimeline.InvokeAsync((moduleId, stage, newDate, isStart));
        }
    }

    private int GetModulePercentage(BuilderModuleDto mod)
    {
        if (!Modules.Any()) return 0;
        var total = Modules.Sum(m => Math.Max(1, m.Weight));
        return (int)Math.Round((double)Math.Max(1, mod.Weight) / total * 100);
    }

    private ModuleStageTimeline? GetTimeline(BuilderModuleDto mod, ModuleStage stage)
    {
        return mod.StageTimelines?.FirstOrDefault(t => t.Stage == stage);
    }

    #endregion

    #region [ Controlo do Modal e Formulários ]

    private void OpenStageModal(BuilderModuleDto mod, (ModuleStage Stage, string Title, string Icon, ModuleStage? CopyFromStage) stageInfo)
    {
        activeModalModule = mod;
        activeModalStage = stageInfo;
        isEditMode = false;
        editModeNewChildren.Clear();
        ResetForm();
    }

    private void CloseStageModal()
    {
        activeModalModule = null;
        activeModalStage = null;
        isEditMode = false;
        editModeNewChildren.Clear();
    }

    private void ResetForm()
    {
        componentToEdit = new BuilderComponentDto();
        drafts = new List<DraftParent> { new DraftParent() };
    }

    /// <summary>
    /// Gere a criação dinâmica de novas caixas de input enquanto o utilizador escreve nos Rascunhos Base.
    /// </summary>
    private void CheckListState(DraftParent currentParent)
    {
        if (!string.IsNullOrWhiteSpace(drafts.Last().Text)) drafts.Add(new DraftParent());
        else if (drafts.Count > 1 && string.IsNullOrWhiteSpace(drafts[^2].Text))
        {
            if (!drafts[^2].Children.Any(f => !string.IsNullOrWhiteSpace(f.Text))) drafts.RemoveAt(drafts.Count - 2);
        }

        if (!string.IsNullOrWhiteSpace(currentParent.Children.Last().Text)) currentParent.Children.Add(new DraftChild());
        else if (currentParent.Children.Count > 1 && string.IsNullOrWhiteSpace(currentParent.Children[^2].Text))
        {
            currentParent.Children.RemoveAt(currentParent.Children.Count - 2);
        }
    }

    #endregion

    #region [ Processamento de Gravações ]

    private async Task SaveRapidStructure()
    {
        if (activeModalModule == null || !activeModalStage.HasValue) return;
        isSavingModal = true;
        await OnSaveRapidStructureEvent.InvokeAsync((activeModalModule.Id, activeModalStage.Value.Stage, drafts));
        isSavingModal = false;
        ResetForm();
    }

    private async Task SaveComponent()
    {
        if (activeModalModule == null || !activeModalStage.HasValue) return;
        isSavingModal = true;
        componentToEdit.Stage = activeModalStage.Value.Stage;
        await OnSaveTheoreticalEvent.InvokeAsync((activeModalModule.Id, componentToEdit));
        isSavingModal = false;
        ResetForm();
    }

    private async Task CopyComponents()
    {
        if (activeModalModule == null || !activeModalStage.HasValue || !activeModalStage.Value.CopyFromStage.HasValue) return;
        isCopying = true;
        await OnCopyComponentsEvent.InvokeAsync((activeModalModule.Id, activeModalStage.Value.Stage, activeModalStage.Value.CopyFromStage.Value));
        isCopying = false;
    }

    #endregion

    #region [ Edição em Massa (Bulk Edit) ]

    private void ToggleEditMode()
    {
        isEditMode = true;
        validationError = null;
        editModeNewChildren.Clear();
    
        var topLevel = activeModalModule?.Components.Where(c => c.ParentComponentId == null && c.Stage == activeModalStage?.Stage).ToList() ?? new();
        foreach (var p in topLevel) editModeNewChildren[p.Id] = new List<DraftChild> { new DraftChild() };
    }

    private void CheckEditModeChildrenState(int parentId)
    {
        var list = editModeNewChildren[parentId];
        if (!string.IsNullOrWhiteSpace(list.Last().Text)) list.Add(new DraftChild());
        else if (list.Count > 1 && string.IsNullOrWhiteSpace(list[^2].Text)) list.RemoveAt(list.Count - 2);
    }

    private async Task SaveChangesBulk()
    {
        if (activeModalModule == null || !activeModalStage.HasValue) return;

        var componentsToUpdate = activeModalModule.Components.Where(c => c.Stage == activeModalStage.Value.Stage).ToList();
        var topLevel = componentsToUpdate.Where(c => c.ParentComponentId == null).ToList();

        // VALIDAÇÃO 1: Os Pais têm de somar 100%
        if (topLevel.Any() && topLevel.Sum(c => c.Weight) != 100)
        {
            validationError = "A soma das percentagens dos parâmetros principais tem de ser exatamente 100%.";
            return;
        }

        // VALIDAÇÃO 2: Os Filhos de cada Pai têm de somar 100% (Contando com os novos!)
        foreach (var parent in topLevel)
        {
            var existingChildren = componentsToUpdate.Where(c => c.ParentComponentId == parent.Id).ToList();
            var newChildren = editModeNewChildren.ContainsKey(parent.Id) ? editModeNewChildren[parent.Id].Where(c => !string.IsNullOrWhiteSpace(c.Text)).ToList() : new();

            var totalWeight = existingChildren.Sum(c => c.Weight) + newChildren.Sum(c => c.Weight);

            if ((existingChildren.Any() || newChildren.Any()) && totalWeight != 100)
            {
                validationError = $"A soma das percentagens dos sub-parâmetros de '{parent.Title}' tem de ser exatamente 100%.";
                return;
            }
        }

        // Sem erros: Prepara empacotamento
        validationError = null;
        isSavingModal = true;

        var newSubTasksDict = new Dictionary<int, List<(string Title, int Weight)>>();
        foreach (var kvp in editModeNewChildren)
        {
            var validTasks = kvp.Value.Where(c => !string.IsNullOrWhiteSpace(c.Text)).Select(c => (c.Text, c.Weight)).ToList();
            if (validTasks.Any()) newSubTasksDict[kvp.Key] = validTasks;
        }

        await OnSaveBulkEditEvent.InvokeAsync((activeModalModule.Id, activeModalStage.Value.Stage, componentsToUpdate, newSubTasksDict));
    
        isSavingModal = false;
        isEditMode = false;
    }

    #endregion
}